<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Client Portal - Gateway Integrator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        @keyframes spin { to { transform: rotate(360deg); } }
        .spin { animation: spin 1s linear infinite; display: inline-block; }
        button:disabled { opacity: 0.6; cursor: not-allowed; }
    </style>
</head>

<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="brand-logo">IG</div>
            <div>
                <div class="brand-title">Gateway Integrator</div>
                <div class="brand-subtitle">API Gateway Integrator</div>
            </div>
        </div>
        <div class="sidebar-menu">
            <div class="menu-group">Workspace</div>
            <% if (currentUser.role !== 'user') { %>
                <a href="/dashboard" class="menu-item">
                    <span class="menu-icon"><i data-lucide="layout-dashboard"></i></span> Overview
                </a>
            <% } %>
            <a href="/client-portal" class="menu-item active">
                <span class="menu-icon"><i data-lucide="zap"></i></span> Simulator API
            </a>

            <% if (currentUser.role !== 'user') { %>
                <div class="menu-group">Service Gateway</div>
                <a href="/dashboard" class="menu-item">
                    <span class="menu-icon"><i data-lucide="server"></i></span> Service
                </a>
                <a href="/api/logs" class="menu-item" target="_blank">
                    <span class="menu-icon"><i data-lucide="clipboard-list"></i></span> Log Request
                </a>
            <% } %>

            <div class="menu-group">System</div>
            <a href="/api/status" class="menu-item" target="_blank">
                <span class="menu-icon"><i data-lucide="activity"></i></span> System Status
            </a>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="breadcrumb">
                <a href="/">Home</a>
                <i data-lucide="chevron-right"></i>
                <a href="#">Gateway System</a>
                <i data-lucide="chevron-right"></i>
                <span style="color: var(--ink); font-weight: 700;">Simulator API</span>
            </div>
            <div class="topbar-actions">
                <button class="btn btn-outline" id="darkModeToggle" title="Ubah Mode Gelap" style="border-radius: 50%; padding: 8px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"><i data-lucide="moon"></i></button>
                <% const sessions = allSessions || {}; const sessionCount = Object.keys(sessions).length; %>
                <% if (sessionCount > 1) { %>
                    <div class="session-switcher">
                        <% for (const [role, info] of Object.entries(sessions)) { %>
                            <a href="/switch-session/<%= role %>" class="session-tab <%= role === activeRole ? 'active' : '' %>" title="Switch ke <%= info.username %> (<%= role %>)">
                                <span class="session-dot session-dot-<%= role %>"></span>
                                <%= info.username %> <span class="session-role-label">(<%= role %>)</span>
                            </a>
                        <% } %>
                    </div>
                <% } else { %>
                    <span class="user-pill"><i data-lucide="user-round"></i><%= currentUser.username %> (<%= currentUser.role %>)</span>
                <% } %>
                <% if (currentUser.role !== 'user') { %>
                    <a href="/dashboard" class="btn btn-outline"><i data-lucide="layout-dashboard"></i> Dashboard</a>
                <% } %>
                <form method="POST" action="/logout" class="logout-form">
                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                    <input type="hidden" name="role" value="<%= currentUser.role %>">
                    <button class="btn btn-outline"><i data-lucide="log-out"></i> Keluar</button>
                </form>
            </div>
        </div>

        <div class="content">
            <div class="page-title">Portal Client & Simulator API</div>
            <div class="page-subtitle">Generate token, test endpoint internal, dan simulasikan request ke service ekosistem UMKM.</div>

            <div class="stats-grid">
                <div class="card" style="margin-bottom: 0;">
                    <div class="card-header">
                        <div class="card-title"><i data-lucide="key-round"></i> Generate Access Token</div>
                    </div>
                    <div class="card-note">Token JWT digunakan sebagai Bearer token pada request API. Masa berlaku 24 jam.</div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">User ID / NPM</label>
                            <input type="text" id="inputUserId" class="form-control" placeholder="cth: 714240061" value="714240061">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Nama</label>
                            <input type="text" id="inputName" class="form-control" placeholder="cth: Ahmad Fauzan" value="Test User">
                        </div>
                    </div>

                    <div style="display: flex; gap: 10px; margin-bottom: 12px;">
                        <input type="text" id="tokenOutput" class="form-control key-display" placeholder="Klik Generate untuk membuat token..." readonly>
                        <button class="btn btn-primary" onclick="generateToken()"><i data-lucide="sparkles"></i> Generate</button>
                    </div>
                    <button class="btn btn-outline" style="width: 100%;" onclick="copyToken()"><i data-lucide="copy"></i> Salin Token</button>
                    <div id="tokenStatus" style="margin-top: 12px;"></div>
                </div>

                <div class="card" style="margin-bottom: 0;">
                    <div class="card-header">
                        <div class="card-title"><i data-lucide="flask-conical"></i> Quick Test Internal</div>
                    </div>
                    <div class="card-note">Test endpoint gateway internal tanpa perlu service downstream berjalan.</div>
                    <div class="quick-grid">
                        <button class="btn btn-outline" onclick="testIntegrator('/integrator/routing_api')"><i data-lucide="route"></i> Routing API</button>
                        <button class="btn btn-outline" onclick="testIntegrator('/integrator/validasi_request')"><i data-lucide="shield-check"></i> Validasi</button>
                        <button class="btn btn-outline" onclick="testIntegrator('/integrator/logging')"><i data-lucide="list-checks"></i> Logging</button>
                        <button class="btn btn-outline" onclick="testIntegrator('/integrator/biaya_layanan_integrasi')"><i data-lucide="coins"></i> Biaya</button>
                    </div>
                    <div style="margin-top: 16px;">
                        <div class="code-block" id="quickResponse" style="max-height: 170px; overflow-y: auto;">// Klik salah satu tombol di atas setelah token tersedia...</div>
                    </div>
                </div>
            </div>

            <div class="card" style="border-color: #bfdbfe;">
                <div class="card-header">
                    <div class="card-title" style="color: var(--brand);"><i data-lucide="send"></i> Simulator API - Uji 6 Aplikasi</div>
                </div>

                <div class="form-group">
                    <label class="form-label">1. Pilih Aplikasi Tujuan</label>
                    <select id="testEndpoint" class="form-control" onchange="updateFeePreview()">
                        <option value="/integrator/smartbank/pembayaran_transaksi" data-svc="smartbank" data-ep="pembayaran_transaksi">1. SmartBank - Pembayaran Transaksi</option>
                        <option value="/integrator/smartbank/manajemen_saldo" data-svc="smartbank" data-ep="manajemen_saldo" data-fee="false">1. SmartBank - Manajemen Saldo</option>
                        <option value="/integrator/marketplace/checkout" data-svc="marketplace" data-ep="checkout">2. Marketplace - Checkout</option>
                        <option value="/integrator/marketplace/browse_produk" data-svc="marketplace" data-ep="browse_produk" data-fee="false">2. Marketplace - Browse Produk</option>
                        <option value="/integrator/pos/input_transaksi" data-svc="pos" data-ep="input_transaksi">3. POS - Input Transaksi</option>
                        <option value="/integrator/supplierhub/order_bahan" data-svc="supplierhub" data-ep="order_bahan">4. SupplierHub - Order Bahan</option>
                        <option value="/integrator/logistikita/gateway/lookup" data-svc="logistikita" data-ep="gateway/lookup">5. LogistiKita - Lookup UMKM</option>
                        <option value="/integrator/logistikita/gateway/profiles" data-svc="logistikita" data-ep="gateway/profiles" data-fee="false">5. LogistiKita - Daftar Profil</option>
                        <option value="/integrator/umkm_insight/ambil_data_transaksi" data-svc="umkm_insight" data-ep="ambil_data_transaksi" data-fee="false">6. UMKM Insight - Ambil Data</option>
                    </select>
                </div>

                <div class="form-grid-wide">
                    <div class="form-group">
                        <label class="form-label">2. Token Bearer</label>
                        <input type="text" id="testToken" class="form-control" placeholder="Paste token di sini...">
                    </div>
                    <div class="form-group">
                        <label class="form-label">3. Amount Transaksi (Rp)</label>
                        <input type="number" id="testAmount" class="form-control" placeholder="cth: 50000" value="50000" oninput="updateFeePreview()">
                    </div>
                </div>

                <div class="fee-preview-box">
                    <span style="display: inline-flex; align-items: center; gap: 8px;"><i data-lucide="badge-dollar-sign"></i> Fee Gateway (0.5%)</span>
                    <span id="feePreview" style="font-size: 18px;">Rp 250</span>
                </div>


                <div id="tokenExpiryWarning" class="token-warning"></div>
                <div class="action-grid">
                    <button onclick="jalankanDemo()" class="btn btn-success"><i data-lucide="play-circle"></i> Demo Simulasi Sukses</button>
                    <button onclick="jalankanLive()" class="btn btn-dark"><i data-lucide="radio-tower"></i> Live Request</button>
                </div>

                <div style="margin-top: 20px;">
                    <label class="form-label">Server Response</label>
                    <div class="code-block" id="jsonResponse" style="min-height: 130px;">// Pilih mode Demo atau Live, lalu jalankan request...</div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="card-title"><i data-lucide="book-open"></i> Panduan Integrasi</div>
                </div>
                <div class="code-block">
<span class="syntax-label">Base URL:</span> <span class="syntax-value">http://localhost:3000/integrator/{service}/{endpoint}</span>

<span class="syntax-label">Header Wajib:</span>
  <span class="syntax-label">Authorization:</span> <span class="syntax-value">Bearer [TOKEN_JWT]</span>
  <span class="syntax-label">Content-Type:</span>  <span class="syntax-value">application/json</span>

<span class="syntax-label">Body (POST):</span>
{
  <span class="syntax-label">"user_id":</span>  <span class="syntax-value">"714240061"</span>,
  <span class="syntax-label">"amount":</span>   <span class="syntax-value">50000</span>,
  <span class="syntax-label">"parameter":</span> <span class="syntax-value">"deskripsi transaksi"</span>
}
                </div>
            </div>
        </div>
    </div>

    <script>
        window.CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content || '';
        function csrfFetch(url, options) {
            const finalOptions = options || {};
            finalOptions.headers = Object.assign({}, finalOptions.headers || {}, { 'X-CSRF-Token': window.CSRF_TOKEN });
            return fetch(url, finalOptions);
        }
        async function generateToken() {
            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="spin"></i> Generating...';
            const userId = document.getElementById('inputUserId').value || '714240061';
            const name = document.getElementById('inputName').value || 'Test User';
            const statusEl = document.getElementById('tokenStatus');

            try {
                const res = await csrfFetch('/generate-test-token', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ user_id: userId, name: name, npm: userId })
                });
                const data = await res.json();
                if (!res.ok || data.status !== 'success') throw new Error(data.message || 'Token gagal dibuat');
                document.getElementById('tokenOutput').value = data.token;
                document.getElementById('testToken').value = data.token;
                const payload = data.payload || {};
                const actualName = payload.name || name;
                const actualUserId = payload.user_id || userId;
                const badge = document.createElement('div');
                badge.className = 'badge badge-success';
                badge.textContent = 'Token API berhasil dibuat untuk ' + actualName + ' (' + actualUserId + ')';
                statusEl.innerHTML = '';
                statusEl.appendChild(badge);
            } catch (err) {
                const badge = document.createElement('div');
                badge.className = 'badge badge-error';
                badge.textContent = 'Gagal generate token: ' + err.message;
                statusEl.innerHTML = '';
                statusEl.appendChild(badge);
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="sparkles"></i> Generate';
                lucide.createIcons();
            }
        }

        async function copyToken() {
            const token = document.getElementById("tokenOutput").value;
            if (!token) return alert("Generate token dulu.");
            try {
                await navigator.clipboard.writeText(token);
                alert("Token berhasil disalin.");
            } catch (err) {
                const el = document.getElementById("tokenOutput");
                el.select();
                document.execCommand("copy");
                alert("Token berhasil disalin.");
            }
        }

        function updateFeePreview() {
            const sel = document.getElementById('testEndpoint');
            const opt = sel.options[sel.selectedIndex];
            const hasFee = opt.dataset.fee !== 'false';
            const amountInput = document.getElementById('testAmount');

            if (!hasFee) {
                amountInput.disabled = true;
                amountInput.value = 0;
                document.getElementById('feePreview').innerHTML = 'Rp 0 <span style="font-weight:600; font-size:12px; color:var(--muted);">(Non-transaksi)</span>';
            } else {
                amountInput.disabled = false;
                if (amountInput.value == 0) amountInput.value = 50000;
                const amount = parseFloat(amountInput.value) || 0;
                const fee = Math.round(amount * 0.005);
                document.getElementById('feePreview').textContent = 'Rp ' + fee.toLocaleString('id-ID');
            }
        }
        function preserveSidebarScroll() {
            const sidebarMenu = document.querySelector('.sidebar-menu');
            if (!sidebarMenu) return;

            const storageKey = 'rplIntegrator.sidebar.scrollTop';
            const activeItem = sidebarMenu.querySelector('.menu-item.active');
            const savedScrollTop = sessionStorage.getItem(storageKey);

            if (savedScrollTop !== null) {
                sidebarMenu.scrollTop = Number(savedScrollTop) || 0;
            }

            const keepActiveVisible = () => {
                if (!activeItem) return;

                const menuRect = sidebarMenu.getBoundingClientRect();
                const activeRect = activeItem.getBoundingClientRect();
                const isAbove = activeRect.top < menuRect.top;
                const isBelow = activeRect.bottom > menuRect.bottom;

                if (isAbove || isBelow) {
                    activeItem.scrollIntoView({ block: 'center', behavior: 'auto' });
                }
            };

            requestAnimationFrame(keepActiveVisible);

            const storeScroll = () => {
                sessionStorage.setItem(storageKey, String(sidebarMenu.scrollTop));
            };

            sidebarMenu.addEventListener('scroll', storeScroll, { passive: true });
            sidebarMenu.querySelectorAll('a.menu-item').forEach((item) => {
                item.addEventListener('click', storeScroll);
            });
            window.addEventListener('beforeunload', storeScroll);
        }
        window.addEventListener('DOMContentLoaded', () => {
                        preserveSidebarScroll();
                        const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                const isDark = localStorage.getItem('darkMode') === 'true';
                if (isDark) document.body.classList.add('dark-mode');

                toggle.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                if (window.lucide) lucide.createIcons();

                // Hapus event listener lama dengan clone node (jika ada script ganda)
                const newToggle = toggle.cloneNode(true);
                toggle.parentNode.replaceChild(newToggle, toggle);

                newToggle.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const dark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', dark);

                    newToggle.innerHTML = dark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                    if (window.lucide) lucide.createIcons();
                });
            } else {
                if (localStorage.getItem('darkMode') === 'true') {
                    document.body.classList.add('dark-mode');
                }
            }
            updateFeePreview();
            lucide.createIcons();
        });

        function getSelectedService() {
            const sel = document.getElementById('testEndpoint');
            const opt = sel.options[sel.selectedIndex];
            return { service: opt.dataset.svc, endpoint: opt.dataset.ep };
        }


        // ── Token Expiry Warning ──
        function checkTokenExpiry() {
            const token = document.getElementById('testToken').value || document.getElementById('tokenOutput').value;
            const warningEl = document.getElementById('tokenExpiryWarning');
            if (!warningEl) return;
            const setTokenWarning = (state, html) => {
                warningEl.classList.remove('is-visible', 'token-warning-expired', 'token-warning-soon', 'token-warning-valid', 'token-warning-neutral');
                if (!state) return;
                warningEl.classList.add('is-visible', 'token-warning-' + state);
                warningEl.innerHTML = html;
                lucide.createIcons();
            };
            if (!token || !token.includes('.')) { setTokenWarning(); return; }

            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                if (!payload.exp) { setTokenWarning(); return; }

                const now = Math.floor(Date.now() / 1000);
                const secsLeft = payload.exp - now;

                if (secsLeft <= 0) {
                    setTokenWarning('expired', '<i data-lucide="alert-circle" class="token-warning-icon"></i> Token sudah <strong>kadaluwarsa</strong>! Generate token baru.');
                } else if (secsLeft < 1800) {
                    const mins = Math.ceil(secsLeft / 60);
                    setTokenWarning('soon', '<i data-lucide="clock" class="token-warning-icon"></i> Token akan kadaluwarsa dalam <strong>' + mins + ' menit</strong>. Segera generate ulang!');
                } else {
                    const hours = Math.floor(secsLeft / 3600);
                    const mins = Math.floor((secsLeft % 3600) / 60);
                    setTokenWarning('valid', '<i data-lucide="check-circle" class="token-warning-icon"></i> Token valid &mdash; berlaku <strong>' + hours + 'h ' + mins + 'm</strong> lagi.');
                }
            } catch(e) {
                setTokenWarning();
            }
        }

        // Update setiap 30 detik
        document.getElementById('testToken').addEventListener('input', checkTokenExpiry);
        setInterval(checkTokenExpiry, 30000);
        async function jalankanDemo() {
            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="spin"></i> Mengirim...';
            const token = document.getElementById('testToken').value;
            let amount = parseFloat(document.getElementById('testAmount').value);
            if (isNaN(amount)) amount = 50000;
            const { service, endpoint } = getSelectedService();
            const responseBox = document.getElementById('jsonResponse');

            responseBox.innerText = "// Menjalankan simulasi ke " + service + "/" + endpoint + "...";
            responseBox.style.color = "#fbbf24";

            try {
                const res = await csrfFetch('/api/demo/simulate', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + (token || '')
                    },
                    body: JSON.stringify({ service, endpoint, amount })
                });
                const data = await res.json();
                responseBox.innerText = JSON.stringify(data, null, 2);
                responseBox.style.color = "#86efac";
            } catch (err) {
                responseBox.innerText = "// Error: " + err.message;
                responseBox.style.color = "#fca5a5";
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="play-circle"></i> Demo Simulasi Sukses';
                lucide.createIcons();
            }
        }

        async function jalankanLive() {
            const btn = event.currentTarget;
            btn.disabled = true;
            btn.innerHTML = '<i data-lucide="loader-2" class="spin"></i> Mengirim...';
            const endpoint = document.getElementById('testEndpoint').value;
            const token = document.getElementById('testToken').value;
            const amount = parseFloat(document.getElementById('testAmount').value) || 0;
            const userId = document.getElementById('inputUserId').value || '714240061';
            const responseBox = document.getElementById('jsonResponse');

            if (!token) return alert("Token wajib diisi. Klik Generate dulu.");

            responseBox.innerText = "// Mengirim live request ke " + endpoint + "...";
            responseBox.style.color = "#fbbf24";

            try {
                // Buat payload dinamis (LogistiKita butuh user_id berupa SmartBank ID)
                const isLogistiKita = endpoint.includes('logistikita');
                const payload = {
                    user_id: isLogistiKita ? "SB-714240035" : userId, // ID valid Asha Clean
                    amount,
                    parameter: "Live request via Client Portal"
                };

                const res = await csrfFetch(endpoint, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'Authorization': 'Bearer ' + token
                    },
                    body: JSON.stringify(payload)
                });
                const data = await res.json();
                responseBox.innerText = JSON.stringify(data, null, 2);
                responseBox.style.color = res.ok ? "#67e8f9" : "#fca5a5";
            } catch (err) {
                responseBox.innerText = "// Error: " + err.message + "\n// Service tujuan belum berjalan.";
                responseBox.style.color = "#fca5a5";
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="radio-tower"></i> Live Request';
                lucide.createIcons();
            }
        }

        async function testIntegrator(path) {
            const token = document.getElementById('testToken').value;
            const responseBox = document.getElementById('quickResponse');

            if (!token) return alert("Generate token dulu sebelum test.");

            responseBox.innerText = "// Testing " + path + "...";
            responseBox.style.color = "#fbbf24";

            try {
                const res = await csrfFetch(path, {
                    headers: { 'Authorization': 'Bearer ' + token }
                });
                const data = await res.json();
                responseBox.innerText = JSON.stringify(data, null, 2);
                responseBox.style.color = "#67e8f9";
            } catch (err) {
                responseBox.innerText = "// Error: " + err.message;
                responseBox.style.color = "#fca5a5";
            }
        }
    </script>
</body>

</html>
