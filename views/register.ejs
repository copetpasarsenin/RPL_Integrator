<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - Gateway Integrator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .login-shell {
            width: min(100%, 980px);
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 420px;
            align-items: center;
            gap: 42px;
            padding: 36px;
        }

        .login-intro {
            color: #ffffff;
        }

        .login-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #93c5fd;
            background: rgba(37, 99, 235, 0.12);
            border: 1px solid rgba(147, 197, 253, 0.22);
            border-radius: 999px;
            padding: 7px 11px;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .login-headline {
            font-size: 44px;
            font-weight: 850;
            line-height: 1.05;
            margin-bottom: 16px;
        }

        .login-copy {
            color: #b6c7da;
            font-size: 16px;
            max-width: 480px;
        }

        .login-card {
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(255, 255, 255, 0.16);
            border-radius: var(--radius);
            padding: 30px;
            box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
            animation: fadeInUp 0.6s ease 0.15s both;
        }

        .login-logo {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 850;
            margin-bottom: 18px;
            animation: glowPulse 3s ease-in-out infinite;
        }

        .login-title {
            font-size: 24px;
            font-weight: 850;
            color: var(--ink);
            margin-bottom: 6px;
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 24px;
        }

        .error-box {
            background: var(--danger-bg);
            color: var(--danger);
            border: 1px solid #fecaca;
            padding: 10px 12px;
            border-radius: var(--radius);
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .success-box {
            background: var(--success-bg);
            color: var(--success);
            border: 1px solid #bbf7d0;
            padding: 10px 12px;
            border-radius: var(--radius);
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .login-help {
            margin-top: 18px;
            font-size: 13px;
            color: var(--muted);
            line-height: 1.6;
            text-align: center;
        }

        .login-help a {
            color: var(--brand);
            font-weight: 700;
            text-decoration: none;
        }

        .login-help a:hover {
            text-decoration: underline;
        }

        @media (max-width: 860px) {
            .login-shell {
                grid-template-columns: 1fr;
                gap: 24px;
                padding: 24px;
            }

            .login-headline {
                font-size: 34px;
            }
        }
    </style>
</head>

<body class="no-sidebar">
    <div class="login-shell">
        <div class="login-intro" style="animation: fadeInUp 0.6s ease both;">
            <div class="login-eyebrow"><i data-lucide="user-plus"></i> Create Account</div>
            <div class="login-headline">Daftar Akun Baru</div>
            <p class="login-copy">Buat akun untuk mengakses Client Portal, membuat token API, dan menjalankan simulasi integrasi layanan.</p>
        </div>

        <form class="login-card" method="POST" action="/register">
            <div class="login-logo">IG</div>
            <div class="login-title">Register</div>
            <div class="login-subtitle">Buat akun baru untuk akses gateway.</div>

            <% if (error) { %>
                <div class="error-box"><%= error %></div>
            <% } %>
            <% if (success) { %>
                <div class="success-box"><%= success %></div>
            <% } %>

            <div class="form-group">
                <label class="form-label" for="username">Username</label>
                <input id="username" name="username" type="text" class="form-control" autocomplete="username" required autofocus placeholder="Masukkan username">
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Password</label>
                <input id="password" name="password" type="password" class="form-control" autocomplete="new-password" required minlength="6" placeholder="Minimal 6 karakter">
            </div>

            <div class="form-group">
                <label class="form-label" for="confirm_password">Konfirmasi Password</label>
                <input id="confirm_password" name="confirm_password" type="password" class="form-control" autocomplete="new-password" required placeholder="Ulangi password">
            </div>

            <button class="btn btn-primary" style="width: 100%; margin-top: 8px;"><i data-lucide="user-plus"></i> Daftar</button>

            <div class="login-help">
                Sudah punya akun? <a href="/login">Login di sini</a>
            </div>
        </form>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => lucide.createIcons());
    </script>
</body>

</html>
