<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login - Gateway Integrator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .login-shell {
            width: min(100%, 980px);
            min-height: 100vh;
            display: grid;
            grid-template-columns: 1fr 420px;
            align-items: center;
            gap: 42px;
            padding: 36px;
        }

        .login-intro {
            color: #ffffff;
        }

        .login-eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: #93c5fd;
            background: rgba(37, 99, 235, 0.12);
            border: 1px solid rgba(147, 197, 253, 0.22);
            border-radius: 999px;
            padding: 7px 11px;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 20px;
        }

        .login-headline {
            font-size: 44px;
            font-weight: 850;
            line-height: 1.05;
            margin-bottom: 16px;
        }

        .login-copy {
            color: #b6c7da;
            font-size: 16px;
            max-width: 480px;
        }

        .login-card {
            width: 100%;
            background: rgba(255, 255, 255, 0.98);
            border: 1px solid rgba(255, 255, 255, 0.16);
            border-radius: var(--radius);
            padding: 30px;
            box-shadow: 0 28px 70px rgba(0, 0, 0, 0.28);
            animation: fadeInUp 0.6s ease 0.15s both;
        }

        .login-logo {
            width: 44px;
            height: 44px;
            border-radius: 10px;
            background: linear-gradient(135deg, var(--brand), var(--cyan));
            color: #ffffff;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 850;
            margin-bottom: 18px;
            animation: glowPulse 3s ease-in-out infinite;
        }

        .login-title {
            font-size: 24px;
            font-weight: 850;
            color: var(--ink);
            margin-bottom: 6px;
        }

        .login-subtitle {
            font-size: 14px;
            color: var(--muted);
            margin-bottom: 24px;
        }

        .error-box {
            background: var(--danger-bg);
            color: var(--danger);
            border: 1px solid #fecaca;
            padding: 10px 12px;
            border-radius: var(--radius);
            font-size: 13px;
            font-weight: 700;
            margin-bottom: 16px;
        }

        .login-help {
            margin-top: 18px;
            font-size: 12px;
            color: var(--muted);
            line-height: 1.6;
        }

        .demo-login-panel {
            margin-top: 18px;
            padding-top: 18px;
            border-top: 1px solid var(--line);
        }

        .demo-login-title {
            font-size: 13px;
            font-weight: 800;
            color: var(--ink);
            margin-bottom: 10px;
        }

        .demo-login-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 8px;
        }

        .demo-note {
            margin-top: 10px;
            font-size: 12px;
            color: var(--muted);
            line-height: 1.5;
        }

        @media (max-width: 860px) {
            .login-shell {
                grid-template-columns: 1fr;
                gap: 24px;
                padding: 24px;
            }

            .login-headline {
                font-size: 34px;
            }

            .demo-login-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="no-sidebar">
    <div style="position:absolute;top:24px;right:24px;z-index:999"><button class="btn btn-outline" id="darkModeToggle" title="Ubah mode tampilan" style="border-radius: 50%; padding: 8px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"><i data-lucide="moon"></i></button></div>
    <div class="login-shell">
        <div class="login-intro" style="animation: fadeInUp 0.6s ease both;">
            <div class="login-eyebrow"><i data-lucide="shield-check"></i> Akses Gateway Aman</div>
            <div class="login-headline">Gateway Integrator</div>
            <p class="login-copy">Masuk ke dashboard operasional untuk memantau request API, routing service, data karyawan, dan efektivitas penggunaan service.</p>
        </div>

        <form class="login-card" method="POST" action="/login">
            <div class="login-logo">IG</div>
            <div class="login-title">Masuk ke Gateway</div>
            <div class="login-subtitle">Gunakan login manual atau akun demo untuk presentasi.</div>

            <% if (error) { %>
                <div class="error-box"><%= error %></div>
            <% } %>

            <div class="form-group">
                <label class="form-label" for="username">Nama pengguna</label>
                <input id="username" name="username" type="text" class="form-control" autocomplete="username" required autofocus>
            </div>

            <div class="form-group">
                <label class="form-label" for="password">Kata sandi</label>
                <input id="password" name="password" type="password" class="form-control" autocomplete="current-password" required>
            </div>

            <button class="btn btn-primary" style="width: 100%; margin-top: 8px;"><i data-lucide="log-in"></i> Masuk Manual</button>

            <div class="demo-login-panel">
                <div class="demo-login-title">Login demo satu klik</div>
                <div class="demo-login-grid">
                    <button class="btn btn-outline" type="submit" name="demo_role" value="admin" formnovalidate>Login sebagai Admin</button>
                    <button class="btn btn-outline" type="submit" name="demo_role" value="operator" formnovalidate>Login sebagai Operator</button>
                    <button class="btn btn-outline" type="submit" name="demo_role" value="user" formnovalidate>Login sebagai User</button>
                </div>
                <div class="demo-note">Akun demo hanya digunakan untuk pengujian dan presentasi.</div>
            </div>

            <div class="login-help">
                Akun awal: admin/admin123, operator/operator123, user/user123.<br>
                Belum punya akun? <a href="/register" style="color: var(--brand); font-weight: 700; text-decoration: none;">Daftar di sini</a>
            </div>
        </form>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
                lucide.createIcons();
                        const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                const isDark = localStorage.getItem('darkMode') === 'true';
                if (isDark) document.body.classList.add('dark-mode');
                
                toggle.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                if (window.lucide) lucide.createIcons();

                // Hapus event listener lama dengan clone node (jika ada script ganda)
                const newToggle = toggle.cloneNode(true);
                toggle.parentNode.replaceChild(newToggle, toggle);

                newToggle.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const dark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', dark);
                    
                    newToggle.innerHTML = dark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                    if (window.lucide) lucide.createIcons();
                });
            } else {
                if (localStorage.getItem('darkMode') === 'true') {
                    document.body.classList.add('dark-mode');
                }
            }
            });
    </script>
</body>

</html>
