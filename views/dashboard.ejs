<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Gateway Integrator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <meta name="csrf-token" content="<%= csrfToken || '' %>">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="brand-logo">IG</div>
            <div>
                <div class="brand-title">Gateway Integrator</div>
                <div class="brand-subtitle">API Gateway Integrator</div>
            </div>
        </div>
        <div class="sidebar-menu">
            <div class="menu-group">Koneksi</div>
            <a href="/dashboard" class="menu-item <%= section === 'overview' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="layout-dashboard"></i></span> Ringkasan Gateway</a>
            <a href="/dashboard/services" class="menu-item <%= section === 'services' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="server"></i></span> Service (<%= serviceCount %>)</a>
            <a href="/dashboard/routes" class="menu-item <%= section === 'routes' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="route"></i></span> Rute</a>
            <a href="/dashboard/consumers" class="menu-item <%= section === 'consumers' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="users"></i></span> Konsumen</a>

            <div class="menu-group">Plugins</div>
            <a href="/dashboard/plugins" class="menu-item <%= section === 'plugins' ? 'active' : '' %>"><span
                class="menu-icon"><i data-lucide="plug"></i></span> Plugins (7)</a>

            <div class="menu-group">Monitoring</div>
            <a href="/dashboard/analytics" class="menu-item <%= section === 'analytics' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="bar-chart-3"></i></span> Analitik</a>
            <a href="/dashboard/logs" class="menu-item <%= section === 'logs' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="clipboard-list"></i></span> Log Request</a>
            <a href="/dashboard/alerts" class="menu-item <%= section === 'alerts' ? 'active' : '' %>"><span
                    class="menu-icon"><i data-lucide="bell-ring"></i></span> Peringatan (<%= openAlertCount || 0 %>)</a>
            <% if (canViewRevenue) { %>
                <a href="/dashboard/revenue" class="menu-item <%= section === 'revenue' ? 'active' : '' %>"><span
                        class="menu-icon"><i data-lucide="coins"></i></span> Pendapatan</a>
                <% } %>

                    <% if (isAdmin) { %>
                        <div class="menu-group">Admin</div>
                        <a href="/dashboard/users" class="menu-item <%= section === 'users' ? 'active' : '' %>"><span
                                class="menu-icon"><i data-lucide="user-cog"></i></span> Manajemen User</a>
                        <a href="/dashboard/apikeys" class="menu-item <%= section === 'apikeys' ? 'active' : '' %>"><span
                                class="menu-icon"><i data-lucide="key-round"></i></span> Kunci API</a>
                        <a href="/dashboard/employees" class="menu-item <%= section === 'employees' ? 'active' : '' %>"><span
                                class="menu-icon"><i data-lucide="id-card"></i></span> Data Karyawan</a>
                        <a href="/dashboard/audit" class="menu-item <%= section === 'audit' ? 'active' : '' %>"><span
                                class="menu-icon"><i data-lucide="shield-alert"></i></span> Log Audit</a>
                        <% } %>
                        <a href="/dashboard/health-history" class="menu-item <%= section === 'health_history' ? 'active' : '' %>"><span
                                class="menu-icon"><i data-lucide="heartbeat"></i></span> Riwayat Health</a>

            <div class="menu-group">Alat</div>
                            <a href="/client-portal" class="menu-item"><span class="menu-icon"><i
                                        data-lucide="zap"></i></span> Simulator API</a>
                            <a href="/dashboard/architecture" class="menu-item <%= section === 'architecture' ? 'active' : '' %>"><span
                                    class="menu-icon"><i data-lucide="network"></i></span> Arsitektur</a>
                            <a href="/dashboard/docs" class="menu-item <%= section === 'docs' ? 'active' : '' %>"><span
                                    class="menu-icon"><i data-lucide="book-open"></i></span> Dokumentasi API</a>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="breadcrumb">
                <a href="/">Beranda</a><i data-lucide="chevron-right"></i>
                <% if (section === 'apikeys') { %>
                    <a href="/dashboard">Admin</a><i data-lucide="chevron-right"></i>
                    <span style="color: var(--ink); font-weight: 700;" id="breadcrumb-current">Kunci API</span>
                <% } else { %>
                    <a href="/dashboard">Gateway</a><i data-lucide="chevron-right"></i>
                    <span style="color: var(--ink); font-weight: 700;" id="breadcrumb-current">
                        <%= section==='overview' ? 'Ringkasan' : section==='services' ? 'Service' : section==='routes'
                            ? 'Rute' : section==='consumers' ? 'Konsumen' : section==='plugins' ? 'Plugins' :
                            section==='analytics' ? 'Analitik' : section==='logs' ? 'Log Request' : section==='users'
                            ? 'User' : section==='revenue' ? 'Pendapatan' : section==='alerts' ? 'Peringatan' : section==='employees' ? 'Data Karyawan' : section==='architecture' ? 'Arsitektur' : section==='docs' ? 'Dokumentasi API' : 'Dashboard' %>
                    </span>
                <% } %>
            </div>
            <div class="topbar-actions">
                <button class="btn btn-outline" id="darkModeToggle" title="Ubah mode tampilan" style="border-radius: 50%; padding: 8px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;">
                    <i data-lucide="moon"></i>
                </button>
                <% const sessions=allSessions || {}; const sessionCount=Object.keys(sessions).length; %>
                    <% if (sessionCount> 1) { %>
                        <div class="session-switcher">
                            <% for (const [role, info] of Object.entries(sessions)) { %>
                                <a href="/switch-session/<%= role %>"
                                    class="session-tab <%= role === activeRole ? 'active' : '' %>"
                                    title="Pindah ke <%= info.username %> (<%= role %>)">
                                    <span class="session-dot session-dot-<%= role %>"></span>
                                    <%= info.username %> <span class="session-role-label">(<%= role %>)</span>
                                </a>
                                <% } %>
                        </div>
                        <% } else { %>
                            <span class="user-pill"><i data-lucide="user-round"></i>
                                <%= currentUser.username %> (<%= currentUser.role %>)
                            </span>
                            <% } %>
                                <form class="logout-form" method="POST" action="/logout">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                                    <input type="hidden" name="role" value="<%= currentUser.role %>">
                                    <button class="btn btn-outline" title="Keluar dari <%= currentUser.role %>"><i
                                            data-lucide="log-out"></i> Keluar</button>
                                </form>
                                <% if (sessionCount> 1) { %>
                                    <form class="logout-form" method="POST" action="/logout-all">
                                        <input type="hidden" name="_csrf" value="<%= csrfToken || '' %>">
                                        <button
                                            class="btn btn-outline" style="color:var(--danger)"
                                            title="Logout semua session"><i data-lucide="x-circle"></i></button></form>
                                    <% } %>
            </div>
        </div>

        <div class="content">
            <!-- ═══════════════════════════════════════════════════════ -->
            <!-- OVERVIEW -->
            <% if (section==='overview' ) { %>
                <div class="page-title">Ringkasan Gateway</div>
                <div class="page-subtitle">Ringkasan status gateway, traffic, dan aktivitas terkini.</div>

                <div class="status-bar" style="display:flex;justify-content:space-between;gap:12px;align-items:center;flex-wrap:wrap">
                    <span><span class="status-dot online"></span> Gateway <strong>Aktif</strong> -
                    Waktu berjalan: <%= Math.floor(uptime / 3600) %>j <%= Math.floor((uptime % 3600) / 60) %>m</span>
                    <% if (isAdmin) { %>
                        <button class="btn btn-outline btn-sm" onclick="seedDemoData()"><i data-lucide="database"></i> Buat Data Demo</button>
                    <% } %>
                </div>

                <% if (alerts && alerts.length > 0) { %>
                    <div class="card" style="margin-bottom:16px;border-color:#fbbf24;background:#fffbeb">
                        <div class="card-header">
                            <div class="card-title"><i data-lucide="bell-ring"></i> Peringatan Aktif</div>
                            <a href="/dashboard/alerts" class="btn btn-outline btn-sm">Lihat Semua</a>
                        </div>
                        <div class="table-wrapper">
                            <table>
                                <tbody>
                                    <% alerts.forEach(a => { %>
                                        <tr>
                                            <td><span class="badge badge-<%= a.severity === 'critical' ? 'error' : a.severity === 'warning' ? 'warning' : 'info' %>"><%= a.severity %></span></td>
                                            <td><strong><%= a.title %></strong><div style="font-size:12px;color:var(--muted)"><%= a.message || '-' %></div></td>
                                            <td style="font-size:12px;color:var(--muted)"><%= new Date(a.created_at).toLocaleString('id-ID') %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                <% } %>

                <div class="stats-grid">
                    <div class="stat-box stat-blue">
                        <div>
                            <div class="stat-title">Service Aktif</div>
                            <div class="stat-value">
                                <%= serviceCount %>
                            </div>
                            <div class="stat-desc">Service terdaftar di gateway</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="server"></i></div>
                    </div>
                    <div class="stat-box stat-green">
                        <div>
                            <div class="stat-title">Total Request</div>
                            <div class="stat-value">
                                <%= totalRequests %>
                            </div>
                            <div class="stat-desc">Tingkat sukses: <%= successRate %>%</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="bar-chart-3"></i></div>
                    </div>
                    <div class="stat-box stat-amber">
                        <div>
                            <div class="stat-title">Konsumen</div>
                            <div class="stat-value">
                                <%= totalConsumers %>
                            </div>
                            <div class="stat-desc">Konsumen API unik</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="users"></i></div>
                    </div>
                    <% if (canViewRevenue) { %>
                        <div class="stat-box stat-red">
                            <div>
                                <div class="stat-title">Pendapatan</div>
                                <div class="stat-value">Rp <%= totalRevenue.toLocaleString('id-ID') %>
                                </div>
                                <div class="stat-desc">Total fee gateway</div>
                            </div>
                            <div class="stat-icon"><i data-lucide="coins"></i></div>
                        </div>
                        <% } %>
                </div>

                <div class="chart-grid">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title"><i data-lucide="trending-up"></i> Traffic 7 Hari Terakhir</div>
                        </div>
                        <div class="chart-box"><canvas id="overviewChart"></canvas></div>
                    </div>
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title"><i data-lucide="activity"></i> Aktivitas Terbaru</div>
                        </div>
                        <div class="table-wrapper">
                            <table>
                                <thead>
                                    <tr>
                                        <th>#</th>
                                        <th>Waktu</th>
                                        <th>Service</th>
                                        <th>User</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% recentLogs.forEach(log=> { %>
                                        <tr>
                                            <td style="color:var(--muted)">#<%= log.id %>
                                            </td>
                                            <td style="font-size:12px;color:var(--muted)">
                                                <%= log.waktu %>
                                            </td>
                                            <td>
                                                <%= log.service_tujuan || '-' %>
                                            </td>
                                            <td>
                                                <%= log.user_id || '-' %>
                                            </td>
                                            <td><span
                                                    class="badge badge-<%= log.status === 'SUCCESS' ? 'success' : log.status === 'ERROR' ? 'error' : 'info' %>">
                                                    <%= log.status %>
                                                </span></td>
                                        </tr>
                                        <% }) %>
                                            <% if (recentLogs.length===0) { %>
                                                <tr>
                                                    <td colspan="5"
                                                        style="text-align:center;padding:24px;color:var(--muted)">Belum
                                                        ada aktivitas</td>
                                                </tr>
                                                <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
                <script id="overviewChartData" type="application/json">{"labels":<%- safeJson(chartLabels) %>,"data":<%- safeJson(chartData) %>}</script>
                <script>
                    window.addEventListener('DOMContentLoaded', function () {
                        var d = JSON.parse(document.getElementById('overviewChartData').textContent);
                        new Chart(document.getElementById('overviewChart'), {
                            type: 'line', data: { labels: d.labels, datasets: [{ label: 'Request', data: d.data, borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)', tension: 0.35, fill: true }] },
                            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } }
                        });
                    });
                </script>

                <!-- ═══════════════════════════════════════════════════════ -->
                <!-- SERVICES -->
                <% } else if (section==='services' ) { %>
                    <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                        <div>
                            <div class="page-title">Service</div>
                            <div class="page-subtitle">Kelola API service yang terdaftar di gateway.</div>
                        </div>
                        <% if (isAdmin) { %><div style="display:flex;gap:8px">
                                <button class="btn btn-outline" onclick="openModal('importCsvModal')"><i data-lucide="upload"></i> Impor CSV</button>
                                <button class="btn btn-success" onclick="openModal('serviceModal')"><i data-lucide="plus"></i> Service Baru</button>
                            </div>
                            <% } %>
                    </div>

                    <div class="card" style="margin-bottom: 16px; margin-top: 16px;">
                        <form class="filter-bar" method="GET" action="/dashboard/services">
                            <input type="text" name="search" class="form-control" placeholder="Cari nama service..." value="<%= filterSearch %>" style="flex:1">
                            <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                            <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                            <button class="btn btn-primary" type="submit"><i data-lucide="search"></i> Cari</button>
                            <% if (filterSearch || dateStart || dateEnd) { %><a href="/dashboard/services" class="btn btn-outline">Reset</a><% } %>
                        </form>
                    </div>

                    <div class="card">
                        <div class="table-wrapper">
                            <table>
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Nama Service</th>
                                        <th>Target URL</th>
                                        <th>Health Path</th>
                                        <th>Status Konfigurasi</th>
                                        <th>Health</th>
                                        <th>Total Request</th>
                                        <th>Aktivitas Terakhir</th>
                                        <% if (isAdmin) { %>
                                            <th>Aksi</th>
                                            <% } %>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% services.forEach(s=> { const st = statsMap[s.id] || {}; %>
                                        <tr>
                                            <td>#<%= s.id %>
                                            </td>
                                            <td><strong>
                                                    <%= s.nama_service %>
                                                </strong></td>
                                            <td><code><%= s.url_tujuan %></code></td>
                                            <td><code><%= s.health_path || '/' %></code></td>
                                            <td><span class="badge badge-<%= s.status_aktif ? 'info' : 'warning' %>">
                                                    <%= s.status_aktif ? 'Aktif' : 'Nonaktif' %>
                                                </span></td>
                                            <td><span class="badge badge-<%= serviceHealth[s.nama_service] === 'Online' ? 'success' : serviceHealth[s.nama_service] === 'Down' ? 'error' : 'warning' %>">
                                                    <%= serviceHealth[s.nama_service] || 'Belum dicek' %>
                                                </span></td>
                                            <td>
                                                <%= st.total_requests || 0 %>
                                            </td>
                                            <td style="font-size:12px;color:var(--muted)">
                                                <%= st.last_activity ? new
                                                    Date(st.last_activity).toLocaleString('id-ID') : '-' %>
                                            </td>
                                            <% if (isAdmin) { %>
                                                <td><button class="btn-icon"
                                                        data-svc-id="<%= s.id %>"
                                                        data-svc-name="<%= s.nama_service %>"
                                                        data-svc-url="<%= s.url_tujuan %>"
                                                        data-svc-health="<%= s.health_path || '/' %>"
                                                        data-svc-status="<%= s.status_aktif %>"
                                                        onclick="editService(this)"
                                                        title="Edit"><i data-lucide="pencil"></i></button><button
                                                        class="btn-icon"
                                                        data-svc-id="<%= s.id %>"
                                                        onclick="testService(this)"
                                                        title="Tes koneksi"><i data-lucide="wifi"></i></button><button
                                                        class="btn-icon btn-icon-danger"
                                                        data-svc-id="<%= s.id %>"
                                                        data-svc-name="<%= s.nama_service %>"
                                                        onclick="deleteService(this)"
                                                        title="Hapus"><i data-lucide="trash-2"></i></button></td>
                                                <% } %>
                                        </tr>
                                        <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Modal Service -->
                    <div class="modal-overlay" id="serviceModal">
                        <div class="modal-dialog">
                            <div class="modal-header"><span class="modal-title" id="serviceModalTitle">Service Baru</span><button class="modal-close"
                                    onclick="closeModal('serviceModal')">&times;</button></div>
                            <form id="serviceForm" onsubmit="submitService(event)">
                                <input type="hidden" id="svcId">
                                <div class="form-group"><label class="form-label">Nama Service</label><input type="text"
                                        id="svcName" class="form-control" placeholder="cth: smartbank" required></div>
                                <div class="form-group"><label class="form-label">Target URL</label><input type="url"
                                        id="svcUrl" class="form-control" placeholder="http://localhost:3001" required>
                                </div>
                                <div class="form-group"><label class="form-label">Health Path</label><input type="text"
                                        id="svcHealthPath" class="form-control" placeholder="/" value="/">
                                </div>
                                <div class="form-group"><label class="form-label">Status</label><select id="svcStatus"
                                        class="form-control">
                                        <option value="1">Aktif</option>
                                        <option value="0">Nonaktif</option>
                                    </select></div>
                                <div class="modal-footer"><button type="button" class="btn btn-outline"
                                        onclick="closeModal('serviceModal')">Batal</button><button type="submit"
                                        class="btn btn-primary" id="svcSubmitBtn">Simpan</button></div>
                            </form>
                        </div>
                    </div>

                    <!-- ═══════════════════════════════════════════════════════ -->
                    <!-- ROUTES -->
                    <% } else if (section==='routes' ) { %>
                        <div class="page-title">Rute</div>
                        <div class="page-subtitle">Peta routing otomatis berdasarkan service yang terdaftar.</div>
                        <div class="card">
                            <div class="table-wrapper">
                                <table>
                                    <thead>
                                        <tr>
                                            <th>Pola Gateway</th>
                                            <th>Aturan Target</th>
                                            <th>Health Check</th>
                                            <th>Service</th>
                                            <th>Auth</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% services.forEach(s=> { %>
                                            <tr>
                                                <td><code>/integrator/<%= s.nama_service %>/{path}</code></td>
                                                <td><code><%= s.url_tujuan %>/{path}</code></td>
                                                <td><code><%= s.health_path || '/' %></code></td>
                                                <td><span class="badge badge-info">
                                                        <%= s.nama_service %>
                                                    </span></td>
                                                <td><span class="badge badge-success">JWT Bearer</span></td>
                                            </tr>
                                            <% }) %>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <!-- ═══════════════════════════════════════════════════════ -->
                        <!-- CONSUMERS -->
                        <% } else if (section==='consumers' ) { %>
                            <div class="page-title">Konsumen</div>
                            <div class="page-subtitle">Daftar consumer yang menggunakan API gateway. Data otomatis dari traffic log.</div>

                            <div class="card" style="margin-bottom: 16px;">
                                <form class="filter-bar" method="GET" action="/dashboard/consumers">
                                    <input type="text" name="search" class="form-control" placeholder="Cari User ID..." value="<%= filterSearch %>" style="flex:1">
                                    <button class="btn btn-primary" type="submit"><i data-lucide="search"></i> Cari</button>
                                    <% if (filterSearch) { %><a href="/dashboard/consumers" class="btn btn-outline">Reset</a><% } %>
                                </form>
                            </div>

                            <div class="card">
                                <div class="table-wrapper">
                                    <table>
                                        <thead>
                                            <tr>
                                                <th>User ID</th>
                                                <th>Total Request</th>
                                                <th>First Seen</th>
                                                <th>Last Seen</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <% consumers.forEach(c=> { %>
                                                <tr>
                                                    <td><strong>
                                                            <%= c.user_id %>
                                                        </strong></td>
                                                    <td>
                                                        <%= c.total_requests %>
                                                    </td>
                                                    <td style="font-size:12px;color:var(--muted)">
                                                        <%= c.first_seen ? new
                                                            Date(c.first_seen).toLocaleString('id-ID') : '-' %>
                                                    </td>
                                                    <td style="font-size:12px;color:var(--muted)">
                                                        <%= c.last_seen ? new Date(c.last_seen).toLocaleString('id-ID')
                                                            : '-' %>
                                                    </td>
                                                </tr>
                                                <% }) %>
                                                    <% if (consumers.length===0) { %>
                                                        <tr>
                                                            <td colspan="4"
                                                                style="text-align:center;padding:32px;color:var(--muted)">
                                                                Belum ada consumer. Jalankan simulasi API untuk membuat
                                                                data.</td>
                                                        </tr>
                                                        <% } %>
                                        </tbody>
                                    </table>
                                </div>
                                <% if (totalPages > 1) { %>
                                <div class="pagination" style="padding: 16px; display: flex; gap: 8px; justify-content: center; align-items: center; border-top: 1px solid var(--border)">
                                    <% if (page > 1) { %><a href="/dashboard/consumers?page=<%= page - 1 %>&search=<%= filterSearch %>" class="btn btn-outline btn-sm">Prev</a><% } %>
                                    <span class="pagination-info" style="color: var(--muted); font-size: 14px;">Page <%= page %> of <%= totalPages %></span>
                                    <% if (page < totalPages) { %><a href="/dashboard/consumers?page=<%= page + 1 %>&search=<%= filterSearch %>" class="btn btn-outline btn-sm">Next</a><% } %>
                                </div>
                                <% } %>
                            </div>

                            <!-- ═══════════════════════════════════════════════════════ -->
                            <!-- PLUGINS -->
                            <% } else if (section==='plugins' ) { %>
                                <div class="page-title">Plugins</div>
                                <div class="page-subtitle">Plugin middleware yang aktif di gateway.</div>
                                <div class="plugin-grid">
                                    <% plugins.forEach(p=> { %>
                                        <div class="plugin-card">
                                            <div class="plugin-header">
                                                <div class="plugin-icon"><i data-lucide="<%= p.icon %>"></i></div><span
                                                    class="badge badge-success">Aktif</span>
                                            </div>
                                            <div class="plugin-name">
                                                <%= p.name %>
                                            </div>
                                            <div class="plugin-desc">
                                                <%= p.desc %>
                                            </div>
                                            <div class="plugin-config">
                                                <% Object.entries(p.config).forEach(([k,v])=> { %><div
                                                        class="config-row"><span class="config-key">
                                                            <%= k %>
                                                        </span><span class="config-val">
                                                            <%= v %>
                                                        </span></div>
                                                    <% }) %>
                                            </div>
                                        </div>
                                        <% }) %>
                                </div>

                                <!-- ═══════════════════════════════════════════════════════ -->
                                <!-- ANALYTICS -->
                                <% } else if (section==='analytics' ) { %>
                                    <div class="page-title">Analitik Gateway</div>
                                    <div class="page-subtitle">Ringkasan traffic, aplikasi sumber, konsumen, dan efektivitas penggunaan service.</div>
                                    <div class="card" style="margin-bottom:16px">
                                        <form class="filter-bar" method="GET" action="/dashboard/analytics">
                                            <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                            <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                            <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                            <a href="/dashboard/analytics" class="btn btn-outline">Reset</a>
                                            <a href="/dashboard/analytics/export?start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline" style="margin-left:auto"><i data-lucide="download"></i> Ekspor CSV</a>
                                        </form>
                                    </div>
                                    <div class="stats-grid analytics-summary-grid">
                                        <div class="stat-box stat-blue"><div><div class="stat-title">Total Request</div><div class="stat-value"><%= totalRequests %></div><div class="stat-desc">Dari request log utama</div></div><div class="stat-icon"><i data-lucide="activity"></i></div></div>
                                        <div class="stat-box stat-red"><div><div class="stat-title">Tingkat Error</div><div class="stat-value"><%= errorRatePercent %>%</div><div class="stat-desc">Berdasarkan request log</div></div><div class="stat-icon"><i data-lucide="alert-triangle"></i></div></div>
                                        <div class="stat-box stat-green"><div><div class="stat-title">Total Penggunaan</div><div class="stat-value"><%= shadowTotalUsage || 0 %></div><div class="stat-desc">Dari tabel shadow</div></div><div class="stat-icon"><i data-lucide="database"></i></div></div>
                                        <div class="stat-box stat-amber"><div><div class="stat-title">Sukses Shadow</div><div class="stat-value"><%= shadowSuccessRate || '0.0' %>%</div><div class="stat-desc"><%= shadowSourceAppCount || 0 %> aplikasi sumber, <%= shadowActiveServiceCount || 0 %> service aktif</div></div><div class="stat-icon"><i data-lucide="badge-check"></i></div></div>
                                    </div>
                                    <div class="chart-grid">
                                        <div class="card"><div class="card-header"><div class="card-title"><i data-lucide="bar-chart-3"></i> Request per Service</div></div><div class="chart-box"><canvas id="svcChart"></canvas></div></div>
                                        <div class="card"><div class="card-header"><div class="card-title"><i data-lucide="trending-up"></i> Timeline Traffic (14 hari)</div></div><div class="chart-box"><canvas id="tlChart"></canvas></div></div>
                                    </div>
                                    <div class="chart-grid">
                                        <div class="card">
                                            <div class="card-header"><div class="card-title"><i data-lucide="app-window"></i> Penggunaan Berdasarkan Aplikasi Sumber</div></div>
                                            <div class="chart-box"><canvas id="sourceAppChart"></canvas></div>
                                            <% if (!sourceUsage || sourceUsage.length===0) { %><div class="empty-state">Belum ada data penggunaan dari tabel shadow.</div><% } %>
                                        </div>
                                        <div class="card">
                                            <div class="card-header"><div class="card-title"><i data-lucide="crown"></i> Konsumen Teratas</div></div>
                                            <div class="table-wrapper"><table><thead><tr><th>User ID</th><th>Total Request</th></tr></thead><tbody>
                                                <% topConsumers.forEach(c=> { %><tr><td><strong><%= c.user_id %></strong></td><td><%= c.total %></td></tr><% }) %>
                                                <% if (topConsumers.length===0) { %><tr><td colspan="2" class="empty-cell">Belum ada data konsumen.</td></tr><% } %>
                                            </tbody></table></div>
                                        </div>
                                    </div>
                                    <div class="card">
                                        <div class="card-header"><div class="card-title"><i data-lucide="badge-check"></i> Efektivitas Penggunaan Service</div></div>
                                        <div class="table-wrapper"><table><thead><tr><th>Service</th><th>Total Penggunaan</th><th>Sukses</th><th>Error</th><th>Tingkat Sukses</th></tr></thead><tbody>
                                            <% serviceEffectiveness.forEach(row => { %>
                                                <tr><td><strong><%= row.service_name %></strong></td><td><%= row.total_usage %></td><td><span class="badge badge-success"><%= row.success_count || 0 %></span></td><td><span class="badge badge-error"><%= row.error_count || 0 %></span></td><td><span class="badge badge-info"><%= row.success_rate || '0.0' %>%</span></td></tr>
                                            <% }) %>
                                            <% if (!serviceEffectiveness || serviceEffectiveness.length===0) { %><tr><td colspan="5" class="empty-cell">Belum ada data efektivitas service dari tabel shadow.</td></tr><% } %>
                                        </tbody></table></div>
                                    </div>
                                    <script id="analyticsChartData" type="application/json">{"svcLabels":<%- safeJson(serviceChart.labels) %>,"svcData":<%- safeJson(serviceChart.data) %>,"tlLabels":<%- safeJson(timelineChart.labels) %>,"tlData":<%- safeJson(timelineChart.data) %>,"sourceLabels":<%- safeJson((sourceUsage || []).map(row => row.source_app)) %>,"sourceData":<%- safeJson((sourceUsage || []).map(row => Number(row.total_usage))) %>}</script>
                                    <script>
                                        window.addEventListener('DOMContentLoaded', function () {
                                            var d = JSON.parse(document.getElementById('analyticsChartData').textContent);
                                            new Chart(document.getElementById('svcChart'), { type: 'bar', data: { labels: d.svcLabels, datasets: [{ label: 'Request', data: d.svcData, backgroundColor: '#2563eb', borderRadius: 6 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } } });
                                            new Chart(document.getElementById('tlChart'), { type: 'line', data: { labels: d.tlLabels, datasets: [{ label: 'Request', data: d.tlData, borderColor: '#059669', backgroundColor: 'rgba(5,150,105,0.1)', tension: 0.35, fill: true }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: { precision: 0 } } } } });
                                            if (d.sourceLabels.length) new Chart(document.getElementById('sourceAppChart'), { type: 'doughnut', data: { labels: d.sourceLabels, datasets: [{ data: d.sourceData, backgroundColor: ['#2563eb', '#059669', '#d97706', '#0891b2', '#7c3aed', '#dc2626', '#475569', '#0f766e'], borderWidth: 0 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } } });
                                        });
                                    </script>

                                    <!-- ═══════════════════════════════════════════════════════ -->
                                    <!-- REQUEST LOGS -->
                                    <% } else if (section==='logs' ) { %>
                                        <div class="page-title">Log Request</div>
                                        <div class="page-subtitle">Seluruh log traffic gateway. Data bersifat read-only
                                            (audit trail).</div>

                                        <div class="card" style="margin-bottom: 16px;">
                                            <form class="filter-bar" method="GET" action="/dashboard/logs">
                                                <select name="service" class="form-control" style="width:auto">
                                                    <option value="">Semua Service</option>
                                                    <% serviceNames.forEach(s=> { %><option value="<%= s %>"
                                                            <%=filterService===s ? 'selected' : '' %>><%= s %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                                <select name="status" class="form-control" style="width:auto">
                                                    <option value="">Semua Status</option>
                                                    <option value="SUCCESS" <%=filterStatus==='SUCCESS' ? 'selected'
                                                        : '' %>>Sukses</option>
                                                    <option value="ERROR" <%=filterStatus==='ERROR' ? 'selected' : '' %>
                                                        >Error</option>
                                                    <option value="PENDING" <%=filterStatus==='PENDING' ? 'selected'
                                                        : '' %>>Menunggu</option>
                                                </select>
                                                <input type="text" name="search" class="form-control"
                                                    placeholder="Cari user_id atau URL..." value="<%= filterSearch %>"
                                                    style="flex:1">
                                                <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                <button class="btn btn-primary" type="submit"><i
                                                        data-lucide="search"></i> Filter</button>
                                                <% if (filterService || filterStatus || filterSearch || dateStart || dateEnd) { %><a
                                                        href="/dashboard/logs" class="btn btn-outline">Reset</a>
                                                    <% } %>
                                                <a href="/dashboard/logs/export?service=<%= filterService %>&status=<%= filterStatus %>&search=<%= filterSearch %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline" style="margin-left:auto"><i data-lucide="download"></i> Ekspor CSV</a>
                                            </form>
                                        </div>

                                        <div class="card">
                                            <div class="card-header">
                                                <div class="card-title"><i data-lucide="clipboard-list"></i> Log (<%=
                                                        totalLogs %> total)</div>
                                            </div>
                                            <div class="table-wrapper">
                                                <table>
                                                    <thead>
                                                        <tr>
                                                            <th>#</th>
                                                            <th>Waktu</th>
                                                            <th>IP</th>
                                                            <th>Metode</th>
                                                            <th>Service</th>
                                                            <th>URL</th>
                                                            <th>User</th>
                                                            <th>Status</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        <% logs.forEach(log=> { %>
                                                            <tr>
                                                                <td style="color:var(--muted)">#<%= log.id %>
                                                                </td>
                                                                <td style="font-size:12px;color:var(--muted)">
                                                                    <%= log.waktu %>
                                                                </td>
                                                                <td style="font-size:12px">
                                                                    <%= log.ip || '-' %>
                                                                </td>
                                                                <td><span class="badge badge-info">
                                                                        <%= log.metode %>
                                                                    </span></td>
                                                                <td>
                                                                    <%= log.service_tujuan || '-' %>
                                                                </td>
                                                                <td style="font-family:monospace;font-size:12px">
                                                                    <%= log.url_tujuan %>
                                                                </td>
                                                                <td>
                                                                    <%= log.user_id || '-' %>
                                                                </td>
                                                                <td><span
                                                                        class="badge badge-<%= log.status === 'SUCCESS' ? 'success' : log.status === 'ERROR' ? 'error' : log.status === 'FORWARDED' ? 'info' : 'warning' %>">
                                                                        <%= log.status %>
                                                                    </span></td>
                                                            </tr>
                                                            <% }) %>
                                                                <% if (logs.length===0) { %>
                                                                    <tr>
                                                                        <td colspan="8"
                                                                            style="text-align:center;padding:32px;color:var(--muted)">
                                                                            Tidak ada log yang sesuai filter.</td>
                                                                    </tr>
                                                                    <% } %>
                                                    </tbody>
                                                </table>
                                            </div>
                                            <% if (totalPages> 1) { %>
                                                <div class="pagination">
                                                    <% if (page> 1) { %><a
                                                            href="/dashboard/logs?page=<%= page - 1 %>&service=<%= filterService %>&status=<%= filterStatus %>&search=<%= filterSearch %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>"
                                                            class="btn btn-outline btn-sm">&laquo; Prev</a>
                                                        <% } %>
                                                            <% for (let i=1; i <=totalPages; i++) { %><a
                                                                    href="/dashboard/logs?page=<%= i %>&service=<%= filterService %>&status=<%= filterStatus %>&search=<%= filterSearch %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>"
                                                                    class="btn btn-sm <%= i === page ? 'btn-primary' : 'btn-outline' %>">
                                                                    <%= i %>
                                                                </a>
                                                                <% } %>
                                                                    <% if (page < totalPages) { %><a
                                                                            href="/dashboard/logs?page=<%= page + 1 %>&service=<%= filterService %>&status=<%= filterStatus %>&search=<%= filterSearch %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>"
                                                                            class="btn btn-outline btn-sm">Next
                                                                            &raquo;</a>
                                                                        <% } %>
                                                </div>
                                                <% } %>
                                        </div>

                                        <!-- ═══════════════════════════════════════════════════════ -->
                                        <!-- USER MANAGEMENT (admin only) -->
                                        <% } else if (section==='users' ) { %>
                                            <div
                                                style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                                                <div>
                                                    <div class="page-title">User Management</div>
                                                    <div class="page-subtitle">Kelola akun admin, operator, dan user.
                                                    </div>
                                                </div>
                                                <button class="btn btn-success" onclick="openModal('userModal')"><i
                                                        data-lucide="plus"></i> User Baru</button>
                                            </div>
                                            <div class="card" style="margin-bottom: 16px; margin-top: 16px;">
                                                <form class="filter-bar" method="GET" action="/dashboard/users">
                                                    <input type="text" name="search" class="form-control" placeholder="Cari nama pengguna..." value="<%= filterSearch %>" style="flex:1">
                                                    <button class="btn btn-primary" type="submit"><i data-lucide="search"></i> Cari</button>
                                                    <% if (filterSearch) { %><a href="/dashboard/users" class="btn btn-outline">Reset</a><% } %>
                                                </form>
                                            </div>
                                            <div class="card">
                                                <div class="table-wrapper">
                                                    <table>
                                                        <thead>
                                                            <tr>
                                                                <th>ID</th>
                                                                <th>Nama Pengguna</th>
                                                                <th>Role</th>
                                                                <th>Dibuat</th>
                                                                <th>Aksi</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% users.forEach(u=> { %>
                                                                <tr>
                                                                    <td>#<%= u.id %>
                                                                    </td>
                                                                    <td><strong>
                                                                            <%= u.username %>
                                                                        </strong></td>
                                                                    <td><span
                                                                            class="badge badge-<%= u.role === 'admin' ? 'error' : u.role === 'operator' ? 'info' : 'success' %>">
                                                                            <%= u.role %>
                                                                        </span></td>
                                                                    <td style="font-size:12px;color:var(--muted)">
                                                                        <%= u.created_at ? new
                                                                            Date(u.created_at).toLocaleString('id-ID')
                                                                            : '-' %>
                                                                    </td>
                                                                    <td><button class="btn-icon"
                                                                            data-user-id="<%= u.id %>"
                                                                            data-user-name="<%= u.username %>"
                                                                            data-user-role="<%= u.role %>"
                                                                            onclick="editUser(this)"
                                                                            title="Edit"><i
                                                                                data-lucide="pencil"></i></button>
                                                                        <button class="btn-icon" data-user-id="<%= u.id %>" data-user-name="<%= u.username %>" onclick="openResetPwd(this)" title="Atur ulang kata sandi"><i data-lucide="key-round"></i></button>
                                                                        <% if (u.id !==currentUser.id) { %><button
                                                                                class="btn-icon btn-icon-danger"
                                                                                data-user-id="<%= u.id %>"
                                                                                data-user-name="<%= u.username %>"
                                                                                onclick="deleteUser(this)"
                                                                                title="Hapus"><i
                                                                                    data-lucide="trash-2"></i></button>
                                                                            <% } %>
                                                                    </td>
                                                                </tr>
                                                                <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                                <% if (totalPages > 1) { %>
                                                <div class="pagination" style="padding: 16px; display: flex; gap: 8px; justify-content: center; align-items: center; border-top: 1px solid var(--border)">
                                                    <% if (page > 1) { %><a href="/dashboard/users?page=<%= page - 1 %>&search=<%= filterSearch %>" class="btn btn-outline btn-sm">Prev</a><% } %>
                                                    <span class="pagination-info" style="color: var(--muted); font-size: 14px;">Page <%= page %> of <%= totalPages %></span>
                                                    <% if (page < totalPages) { %><a href="/dashboard/users?page=<%= page + 1 %>&search=<%= filterSearch %>" class="btn btn-outline btn-sm">Next</a><% } %>
                                                </div>
                                                <% } %>
                                            </div>

                                            <!-- Modal User -->
                                            <div class="modal-overlay" id="userModal">
                                                <div class="modal-dialog">
                                                    <div class="modal-header"><span class="modal-title"
                                                            id="userModalTitle">User Baru</span><button
                                                            class="modal-close"
                                                            onclick="closeModal('userModal')">&times;</button></div>
                                                    <form id="userForm" onsubmit="submitUser(event)">
                                                        <input type="hidden" id="userId">
                                                        <div class="form-group"><label
                                                                class="form-label">Nama Pengguna</label><input type="text"
                                                                id="userName" class="form-control" required></div>
                                                        <div class="form-group"><label class="form-label"
                                                                id="pwdLabel">Kata Sandi</label><input type="password"
                                                                id="userPwd" class="form-control"></div>
                                                        <div class="form-group"><label
                                                                class="form-label">Role</label><select id="userRole"
                                                                class="form-control">
                                                                <option value="admin">Admin</option>
                                                                <option value="operator">Operator</option>
                                                                <option value="user">User</option>
                                                            </select></div>
                                                        <div class="modal-footer"><button type="button"
                                                                class="btn btn-outline"
                                                                onclick="closeModal('userModal')">Batal</button><button
                                                                type="submit" class="btn btn-primary">Simpan</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>

                                            <!-- ═══════════════════════════════════════════════════════ -->
                                            <!-- REVENUE (admin only) -->
                                            <% } else if (section==='revenue' ) { %>
                                                <div class="page-title" style="display: flex; justify-content: space-between; align-items: center;">
                                                    Pendapatan
                                                    <a href="/dashboard/revenue/export?start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline"><i data-lucide="download"></i> Ekspor CSV</a>
                                                </div>
                                                <div class="page-subtitle">Pendapatan gateway dari fee layanan
                                                    integrasi. Data bersifat read-only (audit trail).</div>
                                                <div class="card" style="margin-bottom:16px">
                                                    <form class="filter-bar" method="GET" action="/dashboard/revenue">
                                                        <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                        <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                        <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                                        <a href="/dashboard/revenue" class="btn btn-outline">Reset</a>
                                                    </form>
                                                </div>
                                                <div class="stats-grid" style="grid-template-columns: 1fr;">
                                                    <div class="stat-box stat-amber">
                                                        <div>
                                                            <div class="stat-title">Total Pendapatan Gateway</div>
                                                            <div class="stat-value">Rp <%=
                                                                    totalRevenue.toLocaleString('id-ID') %>
                                                            </div>
                                                            <div class="stat-desc">Fee 0.5% dari setiap transaksi</div>
                                                        </div>
                                                        <div class="stat-icon"><i data-lucide="coins"></i></div>
                                                    </div>
                                                </div>
                                                <div class="card">
                                                    <div class="card-header">
                                                        <div class="card-title"><i data-lucide="line-chart"></i>
                                                            Pendapatan per Hari</div>
                                                    </div>
                                                    <div class="chart-box"><canvas id="revChart"></canvas></div>
                                                </div>
                                                <% if (revenueByService.length> 0) { %>
                                                    <div class="card">
                                                        <div class="card-header">
                                                            <div class="card-title"><i data-lucide="pie-chart"></i>
                                                                Breakdown per Service</div>
                                                        </div>
                                                        <div class="table-wrapper">
                                                            <table>
                                                                <thead>
                                                                    <tr>
                                                                        <th>Service</th>
                                                                        <th>Total Fee</th>
                                                                        <th>Transaksi</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>
                                                                    <% revenueByService.forEach(r=> { %><tr>
                                                                            <td><strong>
                                                                                    <%= r.service %>
                                                                                </strong></td>
                                                                            <td>Rp <%=
                                                                                    parseFloat(r.total_fee).toLocaleString('id-ID')
                                                                                    %>
                                                                            </td>
                                                                            <td>
                                                                                <%= r.transactions %>
                                                                            </td>
                                                                        </tr>
                                                                        <% }) %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
                                                    <% } %>
                                                        <script id="revenueChartData" type="application/json">{"labels":<%- safeJson(revenueChart.labels) %>,"data":<%- safeJson(revenueChart.data) %>}</script>
                                                        <script>
                                                            window.addEventListener('DOMContentLoaded', function () {
                                                                var d = JSON.parse(document.getElementById('revenueChartData').textContent);
                                                                new Chart(document.getElementById('revChart'), { type: 'line', data: { labels: d.labels, datasets: [{ label: 'Pendapatan', data: d.data, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.1)', tension: 0.35, fill: true }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
                                                            });
                                                        </script>

                                                        <!-- API KEYS -->
                                                        <% } else if (section==='apikeys') { %>
                                                            <% const totalApiKeys = apiKeys.length;
                                                               const activeApiKeys = apiKeys.filter(k => k.is_active).length;
                                                               const requestsToday = apiKeys.reduce((sum, k) => sum + Number(k.usage_today || 0), 0);
                                                               const dailyQuotaTotal = apiKeys.reduce((sum, k) => sum + Number(k.daily_limit || 1000), 0);
                                                               const quotaUsedPercent = dailyQuotaTotal > 0 ? ((requestsToday / dailyQuotaTotal) * 100).toFixed(1) : '0.0'; %>
                                                            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                                                                <div>
                                                                    <div class="page-title">Kunci API</div>
                                                                    <div class="page-subtitle">Kelola API Key untuk akses integrasi service melalui gateway.</div>
                                                                </div>
                                                                <button class="btn btn-success" onclick="openModal('newKeyModal')"><i data-lucide="plus"></i> Buat Key Baru</button>
                                                            </div>

                                                            <div class="stats-grid apikey-summary-grid" style="margin-top:16px">
                                                                <div class="stat-box stat-blue"><div><div class="stat-title">Total API Key</div><div class="stat-value"><%= totalApiKeys %></div><div class="stat-desc">Semua key terdaftar</div></div><div class="stat-icon"><i data-lucide="key-round"></i></div></div>
                                                                <div class="stat-box stat-green"><div><div class="stat-title">Key Aktif</div><div class="stat-value"><%= activeApiKeys %></div><div class="stat-desc">Dapat digunakan saat ini</div></div><div class="stat-icon"><i data-lucide="badge-check"></i></div></div>
                                                                <div class="stat-box stat-amber"><div><div class="stat-title">Request Hari Ini</div><div class="stat-value"><%= requestsToday %></div><div class="stat-desc">Akumulasi penggunaan harian</div></div><div class="stat-icon"><i data-lucide="activity"></i></div></div>
                                                                <div class="stat-box stat-red"><div><div class="stat-title">Kuota Terpakai</div><div class="stat-value"><%= quotaUsedPercent %>%</div><div class="stat-desc"><%= requestsToday %> dari <%= dailyQuotaTotal %> kuota</div></div><div class="stat-icon"><i data-lucide="gauge"></i></div></div>
                                                            </div>

                                                            <div class="card apikey-guide-card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="book-open-check"></i> Panduan Penggunaan API Key</div></div>
                                                                <div class="apikey-guide-grid">
                                                                    <div><span class="guide-label">Header</span><code>Authorization: Bearer igw_xxxxx</code></div>
                                                                    <div><span class="guide-label">Endpoint</span><code>/integrator/:service/:path</code></div>
                                                                    <div><span class="guide-label">Keamanan</span><span class="guide-text">Simpan token secara privat dan jangan unggah ke repository.</span></div>
                                                                </div>
                                                            </div>

                                                            <div class="card apikey-table-card">
                                                                <div class="card-header">
                                                                    <div class="card-title"><i data-lucide="key-round"></i> Daftar Kunci API</div>
                                                                    <span class="card-note" style="margin:0">Token penuh hanya tampil saat pertama kali dibuat.</span>
                                                                </div>
                                                                <div class="table-wrapper">
                                                                    <table class="apikey-table">
                                                                        <thead><tr><th>#</th><th>Nama Key</th><th>Pemilik</th><th>Prefix</th><th>Kuota Hari Ini</th><th>Status</th><th>Terakhir Dipakai</th><th>Dibuat</th><th>Aksi</th></tr></thead>
                                                                        <tbody>
                                                                        <% apiKeys.forEach(k => { %>
                                                                            <% const usedToday = Number(k.usage_today || 0); const dailyLimit = Number(k.daily_limit || 1000); const usedPercent = dailyLimit > 0 ? Math.min(100, Math.round((usedToday / dailyLimit) * 100)) : 0; %>
                                                                            <tr>
                                                                                <td style="color:var(--muted)">#<%= k.id %></td>
                                                                                <td><strong><%= k.key_name %></strong><div class="table-subtext"><%= k.scopes || 'proxy:*' %></div></td>
                                                                                <td><%= k.username %></td>
                                                                                <td><div class="key-prefix-cell"><code><%= k.api_key_prefix %></code><button class="btn-icon" type="button" data-prefix="<%= k.api_key_prefix %>" onclick="copyApiKeyPrefix(this)" title="Salin prefix"><i data-lucide="copy"></i></button></div></td>
                                                                                <td><div class="quota-cell"><span><%= usedToday %> / <%= dailyLimit %></span><div class="quota-meter"><span style="width:<%= usedPercent %>%"></span></div></div></td>
                                                                                <td><span class="badge badge-<%= k.is_active ? 'success' : 'warning' %>"><span class="badge-dot"></span><%= k.is_active ? 'Aktif' : 'Dicabut' %></span></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= k.last_used ? new Date(k.last_used).toLocaleString('id-ID') : 'Belum digunakan' %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(k.created_at).toLocaleString('id-ID') %></td>
                                                                                <td><% if (k.is_active) { %><button class="btn-icon btn-icon-danger" onclick="revokeKey(<%= k.id %>)" title="Cabut key"><i data-lucide="trash-2"></i></button><% } else { %><span class="table-subtext">Tidak ada aksi</span><% } %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (apiKeys.length === 0) { %><tr><td colspan="9" class="empty-cell"><strong>Belum ada API Key.</strong><br>Buat key baru untuk mulai mengakses endpoint integrator.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                            <!-- Modal Buat Key -->
                                                            <div class="modal-overlay" id="newKeyModal">
                                                                <div class="modal-dialog">
                                                                    <div class="modal-header"><span class="modal-title">Buat API Key Baru</span><button class="modal-close" onclick="closeModal('newKeyModal')">&times;</button></div>
                                                                    <div class="form-group"><label class="form-label">Nama Key</label><input type="text" id="newKeyName" class="form-control" placeholder="cth: Key Produksi, Key Pengujian..."></div>
                                                                    <div class="form-group"><label class="form-label">Limit Harian</label><input type="number" id="newKeyDailyLimit" class="form-control" min="1" max="100000" value="1000"></div>
                                                                    <div id="newKeyResult" style="margin:12px 0;display:none">
                                                                        <div class="card-note" style="background:#fef08a;color:#713f12;border-color:#fbbf24;font-weight:600">Salin API Key berikut sekarang. Token penuh tidak akan ditampilkan lagi.</div>
                                                                        <input type="text" id="newKeyValue" class="form-control" readonly style="font-family:monospace;font-size:12px;margin-top:8px">
                                                                        <button class="btn btn-outline" style="width:100%;margin-top:8px" onclick="copyNewKey()"><i data-lucide="copy"></i> Salin Key</button>
                                                                    </div>
                                                                    <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('newKeyModal')">Tutup</button><button class="btn btn-success" onclick="generateApiKey()"><i data-lucide="sparkles"></i> Buat Key</button></div>
                                                                </div>
                                                            </div>
                                                            <script>
                                                            async function generateApiKey() {
                                                                const name = document.getElementById('newKeyName').value.trim();
                                                                const daily_limit = parseInt(document.getElementById('newKeyDailyLimit').value, 10) || 1000;
                                                                if (!name || name.length < 3) return alert('Nama key minimal 3 karakter');
                                                                try {
                                                                    const r = await csrfFetch('/api/keys', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({key_name: name, daily_limit}) });
                                                                    const d = await r.json();
                                                                    if (d.status === 'success') {
                                                                        document.getElementById('newKeyValue').value = d.api_key;
                                                                        document.getElementById('newKeyResult').style.display = 'block';
                                                                        lucide.createIcons();
                                                                    } else { alert('Error: ' + d.message); }
                                                                } catch(e) { alert('Gagal generate: ' + e.message); }
                                                            }
                                                            async function revokeKey(id) {
                                                                if (!confirm('Yakin revoke API Key ini? Tidak bisa diaktifkan kembali.')) return;
                                                                const r = await csrfFetch('/api/keys/' + id, { method:'DELETE' });
                                                                const d = await r.json();
                                                                if (d.status === 'success') location.reload();
                                                                else alert('Error: ' + d.message);
                                                            }
                                                            function copyNewKey() {
                                                                const el = document.getElementById('newKeyValue');
                                                                el.select();
                                                                navigator.clipboard?.writeText(el.value) || document.execCommand('copy');
                                                                alert('API Key berhasil disalin!');
                                                            }
                                                            function copyApiKeyPrefix(button) {
                                                                const prefix = button.dataset.prefix || '';
                                                                if (!prefix) return alert('Prefix API Key tidak tersedia');
                                                                if (navigator.clipboard?.writeText) {
                                                                    navigator.clipboard.writeText(prefix).then(() => alert('Prefix API Key berhasil disalin'));
                                                                } else {
                                                                    const temp = document.createElement('input');
                                                                    temp.value = prefix;
                                                                    document.body.appendChild(temp);
                                                                    temp.select();
                                                                    document.execCommand('copy');
                                                                    temp.remove();
                                                                    alert('Prefix API Key berhasil disalin');
                                                                }
                                                            }
                                                            </script>

                                                        <!-- DATA KARYAWAN -->
                                                        <% } else if (section==='employees') { %>
                                                            <div class="page-title">Data Karyawan</div>
                                                            <div class="page-subtitle">Data demo karyawan untuk kebutuhan presentasi dan bukti repository.</div>
                                                            <div class="stats-grid">
                                                                <div class="stat-box stat-blue"><div><div class="stat-title">Total Karyawan</div><div class="stat-value"><%= employeeSummary.total || 0 %></div><div class="stat-desc">Semua data demo</div></div><div class="stat-icon"><i data-lucide="id-card"></i></div></div>
                                                                <div class="stat-box stat-red"><div><div class="stat-title">Admin</div><div class="stat-value"><%= employeeSummary.admin_count || 0 %></div><div class="stat-desc">Role administrator</div></div><div class="stat-icon"><i data-lucide="shield-check"></i></div></div>
                                                                <div class="stat-box stat-amber"><div><div class="stat-title">Operator</div><div class="stat-value"><%= employeeSummary.operator_count || 0 %></div><div class="stat-desc">Role operasional</div></div><div class="stat-icon"><i data-lucide="headphones"></i></div></div>
                                                                <div class="stat-box stat-green"><div><div class="stat-title">Staff Aktif</div><div class="stat-value"><%= employeeSummary.active_count || 0 %></div><div class="stat-desc">Status aktif</div></div><div class="stat-icon"><i data-lucide="badge-check"></i></div></div>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="users-round"></i> Daftar Karyawan Demo</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Kode</th><th>Nama</th><th>Role</th><th>Departemen</th><th>Email</th><th>Telepon</th><th>Status</th></tr></thead>
                                                                        <tbody>
                                                                            <% employees.forEach(emp => { %>
                                                                                <tr>
                                                                                    <td><code><%= emp.employee_code %></code></td>
                                                                                    <td><strong><%= emp.name %></strong></td>
                                                                                    <td><span class="badge badge-<%= emp.role === 'admin' ? 'error' : emp.role === 'operator' ? 'info' : 'warning' %>"><%= emp.role %></span></td>
                                                                                    <td><%= emp.department %></td>
                                                                                    <td><%= emp.email %></td>
                                                                                    <td><%= emp.phone || '-' %></td>
                                                                                    <td><span class="badge badge-<%= emp.status === 'active' ? 'success' : 'warning' %>"><%= emp.status === 'active' ? 'Aktif' : 'Nonaktif' %></span></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                            <% if (!employees || employees.length === 0) { %><tr><td colspan="7" class="empty-cell">Belum ada data karyawan.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>

                                                        <!-- AUDIT LOG -->
                                                        <% } else if (section==='audit') { %>
                                                            <div class="page-title">Log Audit</div>
                                                            <div class="page-subtitle">Rekaman semua aksi admin dan operator di sistem.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/audit">
                                                                    <select name="action" class="form-control" style="width:auto">
                                                                        <option value="">Semua Aksi</option>
                                                                        <option value="CREATE_SERVICE" <%=filterAction==='CREATE_SERVICE'?'selected':''%>>Buat Service</option>
                                                                        <option value="UPDATE_SERVICE" <%=filterAction==='UPDATE_SERVICE'?'selected':''%>>Ubah Service</option>
                                                                        <option value="DELETE_SERVICE" <%=filterAction==='DELETE_SERVICE'?'selected':''%>>Hapus Service</option>
                                                                        <option value="CREATE_USER" <%=filterAction==='CREATE_USER'?'selected':''%>>Buat User</option>
                                                                        <option value="DELETE_USER" <%=filterAction==='DELETE_USER'?'selected':''%>>Hapus User</option>
                                                                        <option value="RESET_PASSWORD" <%=filterAction==='RESET_PASSWORD'?'selected':''%>>Atur Ulang Kata Sandi</option>
                                                                        <option value="CREATE_API_KEY" <%=filterAction==='CREATE_API_KEY'?'selected':''%>>Buat API Key</option>
                                                                        <option value="REVOKE_API_KEY" <%=filterAction==='REVOKE_API_KEY'?'selected':''%>>Cabut API Key</option>
                                                                        <option value="IMPORT_SERVICES" <%=filterAction==='IMPORT_SERVICES'?'selected':''%>>Impor Service</option>
                                                                    </select>
                                                                    <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                                    <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="search"></i> Filter</button>
                                                                    <% if (filterAction || dateStart || dateEnd) { %><a href="/dashboard/audit" class="btn btn-outline">Reset</a><% } %>
                                                                    <a href="/dashboard/audit/export?action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline" style="margin-left:auto"><i data-lucide="download"></i> Ekspor CSV</a>
                                                                </form>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="shield-alert"></i> Log Audit (<%= total %> total)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>#</th><th>Waktu</th><th>User</th><th>Aksi</th><th>Resource</th><th>Detail</th><th>IP</th></tr></thead>
                                                                        <tbody>
                                                                        <% auditLogs.forEach(log => { %>
                                                                            <tr>
                                                                                <td style="color:var(--muted)">#<%= log.id %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(log.created_at).toLocaleString('id-ID') %></td>
                                                                                <td><strong><%= log.username || '-' %></strong></td>
                                                                                <td><span class="badge badge-<%= log.action.includes('DELETE')||log.action.includes('REVOKE') ? 'error' : log.action.includes('CREATE')||log.action.includes('IMPORT') ? 'success' : 'info' %>"><%= log.action %></span></td>
                                                                                <td><%= log.resource || '-' %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= log.detail || '-' %></td>
                                                                                <td style="font-size:12px"><%= log.ip || '-' %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (auditLogs.length === 0) { %><tr><td colspan="7" style="text-align:center;padding:32px;color:var(--muted)">Belum ada audit log.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                                <% if (totalPages > 1) { %>
                                                                <div style="padding:16px;display:flex;gap:8px;justify-content:center;border-top:1px solid var(--border)">
                                                                    <% if (page > 1) { %><a href="/dashboard/audit?page=<%= page-1 %>&action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline btn-sm">Sebelumnya</a><% } %>
                                                                    <span style="color:var(--muted);font-size:14px">Halaman <%= page %> dari <%= totalPages %></span>
                                                                    <% if (page < totalPages) { %><a href="/dashboard/audit?page=<%= page+1 %>&action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline btn-sm">Berikutnya</a><% } %>
                                                                </div>
                                                                <% } %>
                                                            </div>

                                                        <!-- HEALTH HISTORY -->
                                                        <% } else if (section==='health_history') { %>
                                                            <div class="page-title">Riwayat Health Service</div>
                                                            <div class="page-subtitle">Rekaman status Online/Down setiap service dalam 24 jam terakhir (dicek setiap 1 menit).</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/health-history">
                                                                    <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                                    <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                                                    <a href="/dashboard/health-history" class="btn btn-outline">Reset</a>
                                                                </form>
                                                            </div>
                                                            <div class="stats-grid">
                                                            <% services.forEach(svc => { const s = summary[svc] || {online:0,down:0}; const total = s.online + s.down; const pct = total > 0 ? Math.round((s.online/total)*100) : 0; %>
                                                                <div class="stat-box <%= pct >= 90 ? 'stat-green' : pct >= 50 ? 'stat-amber' : 'stat-red' %>">
                                                                    <div>
                                                                        <div class="stat-title"><%= svc %></div>
                                                                        <div class="stat-value"><%= pct %>%</div>
                                                                        <div class="stat-desc">Uptime 24 jam &bull; <span style="color:#86efac"><%= s.online %> Online</span> / <span style="color:#fca5a5"><%= s.down %> Down</span></div>
                                                                    </div>
                                                                    <div class="stat-icon"><i data-lucide="<%= pct >= 90 ? 'check-circle' : pct >= 50 ? 'alert-circle' : 'x-circle' %>"></i></div>
                                                                </div>
                                                            <% }) %>
                                                            <% if (services.length === 0) { %>
                                                                <div class="card" style="grid-column:1/-1;text-align:center;padding:32px;color:var(--muted)">Belum ada data health history. Tunggu health check berjalan (setiap 1 menit).</div>
                                                            <% } %>
                                                            </div>
                                                            <div class="card" style="margin-top:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="activity"></i> Log Terbaru (24 jam)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Status</th><th>Waktu Check</th></tr></thead>
                                                                        <tbody>
                                                                        <% healthLogs.slice().reverse().slice(0,50).forEach(log => { %>
                                                                            <tr>
                                                                                <td><strong><%= log.service_name %></strong></td>
                                                                                <td><span class="badge badge-<%= log.status==='Online'?'success':'error' %>"><%= log.status %></span></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(log.checked_at).toLocaleString('id-ID') %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (healthLogs.length === 0) { %><tr><td colspan="3" style="text-align:center;padding:24px;color:var(--muted)">Belum ada data.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } else if (section==='alerts') { %>
                                                            <div class="page-title">System Alerts</div>
                                                            <div class="page-subtitle">Incident feed otomatis dari health monitoring dan aksi operasional gateway.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/alerts">
                                                                    <select name="status" class="form-control" style="width:auto">
                                                                        <option value="open" <%= alertStatus === 'open' ? 'selected' : '' %>>Open</option>
                                                                        <option value="resolved" <%= alertStatus === 'resolved' ? 'selected' : '' %>>Resolved</option>
                                                                        <option value="all" <%= alertStatus === 'all' ? 'selected' : '' %>>All</option>
                                                                    </select>
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                                                </form>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="bell-ring"></i> Alerts (<%= total %> total)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>#</th><th>Severity</th><th>Sumber</th><th>Judul</th><th>Pesan</th><th>Status</th><th>Dibuat</th><th>Aksi</th></tr></thead>
                                                                        <tbody>
                                                                            <% alerts.forEach(a => { %>
                                                                                <tr>
                                                                                    <td style="color:var(--muted)">#<%= a.id %></td>
                                                                                    <td><span class="badge badge-<%= a.severity === 'critical' ? 'error' : a.severity === 'warning' ? 'warning' : 'info' %>"><%= a.severity %></span></td>
                                                                                    <td><code><%= a.source %></code></td>
                                                                                    <td><strong><%= a.title %></strong></td>
                                                                                    <td style="font-size:12px;color:var(--muted)"><%= a.message || '-' %></td>
                                                                                    <td><span class="badge badge-<%= a.is_resolved ? 'success' : 'error' %>"><%= a.is_resolved ? 'Resolved' : 'Open' %></span></td>
                                                                                    <td style="font-size:12px;color:var(--muted)"><%= new Date(a.created_at).toLocaleString('id-ID') %></td>
                                                                                    <td><% if (!a.is_resolved) { %><button class="btn btn-outline btn-sm" onclick="resolveAlert(<%= a.id %>)"><i data-lucide="check-circle"></i> Resolve</button><% } %></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                            <% if (alerts.length === 0) { %><tr><td colspan="8" style="text-align:center;padding:32px;color:var(--muted)">Tidak ada alert.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                                <% if (totalPages > 1) { %>
                                                                    <div class="pagination">
                                                                        <% if (page > 1) { %><a href="/dashboard/alerts?page=<%= page - 1 %>&status=<%= alertStatus %>" class="btn btn-outline btn-sm">Prev</a><% } %>
                                                                        <span style="color:var(--muted);font-size:14px">Page <%= page %> of <%= totalPages %></span>
                                                                        <% if (page < totalPages) { %><a href="/dashboard/alerts?page=<%= page + 1 %>&status=<%= alertStatus %>" class="btn btn-outline btn-sm">Next</a><% } %>
                                                                    </div>
                                                                <% } %>
                                                            </div>
                                                        <% } else if (section==='architecture') { %>
                                                            <div class="page-title">Arsitektur Sistem</div>
                                                            <div class="page-subtitle">Peta modul, alur request, dan service ekosistem yang digunakan gateway.</div>
                                                            <div class="plugin-grid" style="margin-bottom:16px">
                                                                <% modules.forEach(m => { %>
                                                                    <div class="plugin-card">
                                                                        <div class="plugin-header"><div class="plugin-icon"><i data-lucide="<%= m.icon %>"></i></div><span class="badge badge-success">Aktif</span></div>
                                                                        <div class="plugin-name"><%= m.name %></div>
                                                                        <div class="plugin-desc"><%= m.desc %></div>
                                                                    </div>
                                                                <% }) %>
                                                            </div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="workflow"></i> Request Flow</div></div>
                                                                <div style="display:grid;gap:10px">
                                                                    <% flows.forEach((f, i) => { %>
                                                                        <div style="display:flex;gap:12px;align-items:flex-start;padding:10px;border:1px solid var(--border);border-radius:8px;background:var(--surface)">
                                                                            <span class="badge badge-info"><%= i + 1 %></span>
                                                                            <div><%= f %></div>
                                                                        </div>
                                                                    <% }) %>
                                                                </div>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="network"></i> Service Topology</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Rute Gateway</th><th>Target URL</th><th>Health</th><th>Status</th></tr></thead>
                                                                        <tbody>
                                                                            <% services.forEach(s => { %>
                                                                                <tr>
                                                                                    <td><strong><%= s.nama_service %></strong></td>
                                                                                    <td><code>/integrator/<%= s.nama_service %>/{path}</code></td>
                                                                                    <td><code><%= s.url_tujuan %></code></td>
                                                                                    <td><code><%= s.health_path || '/' %></code></td>
                                                                                    <td><span class="badge badge-<%= s.status_aktif ? 'success' : 'warning' %>"><%= s.status_aktif ? 'Aktif' : 'Nonaktif' %></span></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } else if (section==='docs') { %>
                                                            <div class="page-title">API Documentation</div>
                                                            <div class="page-subtitle">Referensi endpoint gateway, format autentikasi, dan route service dinamis.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="key-round"></i> Authentication</div></div>
                                                                <div class="card-note">Gunakan header <code>Authorization: Bearer &lt;JWT atau API Key igw_...&gt;</code>. JWT bisa dibuat dari Simulator API, sedangkan API Key dikelola dari menu Kunci API.</div>
                                                            </div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="book-open"></i> Endpoint Utama</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Metode</th><th>Path</th><th>Auth</th><th>Deskripsi</th></tr></thead>
                                                                        <tbody>
                                                                            <% docs.forEach(d => { %>
                                                                                <tr>
                                                                                    <td><span class="badge badge-info"><%= d.method %></span></td>
                                                                                    <td><code><%= d.path %></code></td>
                                                                                    <td><%= d.auth %></td>
                                                                                    <td><%= d.desc %></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="route"></i> Route Dinamis dari Database</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Gateway URL</th><th>Target URL</th><th>Health Path</th><th>Status</th></tr></thead>
                                                                        <tbody>
                                                                            <% services.forEach(s => { %>
                                                                                <tr>
                                                                                    <td><strong><%= s.nama_service %></strong></td>
                                                                                    <td><code>/integrator/<%= s.nama_service %>/{path}</code></td>
                                                                                    <td><code><%= s.url_tujuan %>/{path}</code></td>
                                                                                    <td><code><%= s.health_path || '/' %></code></td>
                                                                                    <td><span class="badge badge-<%= s.status_aktif ? 'success' : 'warning' %>"><%= s.status_aktif ? 'Aktif' : 'Nonaktif' %></span></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } %>
        </div>
    </div>

    <!-- ═══ GLOBAL SCRIPTS ═══ -->
    <script>
        window.CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content || '';
        function csrfFetch(url, options) {
            const finalOptions = options || {};
            finalOptions.headers = Object.assign({}, finalOptions.headers || {}, { 'X-CSRF-Token': window.CSRF_TOKEN });
            return fetch(url, finalOptions);
        }
        function openModal(id) { document.getElementById(id).classList.add('active'); }
        function closeModal(id) { document.getElementById(id).classList.remove('active'); }

        // ── Services CRUD ──
        function editService(el) {
            document.getElementById('serviceModalTitle').textContent = 'Ubah Service';
            document.getElementById('svcId').value = el.dataset.svcId;
            document.getElementById('svcName').value = el.dataset.svcName;
            document.getElementById('svcUrl').value = el.dataset.svcUrl;
            document.getElementById('svcHealthPath').value = el.dataset.svcHealth || '/';
            document.getElementById('svcStatus').value = el.dataset.svcStatus;
            document.getElementById('svcName').readOnly = true;
            openModal('serviceModal');
        }
        async function submitService(e) {
            e.preventDefault();
            const id = document.getElementById('svcId').value;
            const body = {
                nama_service: document.getElementById('svcName').value,
                url_tujuan: document.getElementById('svcUrl').value,
                health_path: document.getElementById('svcHealthPath').value || '/',
                status_aktif: parseInt(document.getElementById('svcStatus').value)
            };
            const url = id ? `/api/services/${id}` : '/api/services';
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await csrfFetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();
                if (res.ok) { location.reload(); } else { alert(data.message); }
            } catch (err) { alert('Error: ' + err.message); }
        }
        function deleteService(el) {
            var id = el.dataset.svcId;
            var name = el.dataset.svcName;
            if (!confirm('Yakin hapus service "' + name + '"? Ini tidak bisa dibatalkan.')) return;
            csrfFetch('/api/services/' + id, { method: 'DELETE' }).then(function (r) { return r.json(); }).then(function (d) { if (d.status === 'success') location.reload(); else alert(d.message); }).catch(function (e) { alert(e.message); });
        }
        async function testService(el) {
            const id = el.dataset.svcId;
            el.disabled = true;
            try {
                const r = await csrfFetch('/api/services/' + id + '/test', { method: 'POST' });
                const d = await r.json();
                if (r.ok) alert('Health check: ' + d.health_status + '\\nHTTP: ' + d.http_status + '\\nLatency: ' + d.latency_ms + 'ms\\nURL: ' + d.health_url);
                else alert('Service Down\\n' + (d.message || 'Tidak bisa dihubungi') + '\\nURL: ' + (d.health_url || '-'));
                location.reload();
            } catch (e) {
                alert('Gagal test service: ' + e.message);
            } finally {
                el.disabled = false;
            }
        }
        // Reset service modal on open for "New"
        document.querySelector('[onclick="openModal(\'serviceModal\')"]')?.addEventListener('click', () => {
            document.getElementById('serviceModalTitle').textContent = 'Service Baru';
            document.getElementById('svcId').value = '';
            document.getElementById('svcName').value = '';
            document.getElementById('svcUrl').value = '';
            document.getElementById('svcHealthPath').value = '/';
            document.getElementById('svcStatus').value = '1';
            document.getElementById('svcName').readOnly = false;
        });

        // ── Users CRUD ──
        function editUser(el) {
            document.getElementById('userModalTitle').textContent = 'Ubah User';
            document.getElementById('userId').value = el.dataset.userId;
            document.getElementById('userName').value = el.dataset.userName;
            document.getElementById('userName').readOnly = true;
            document.getElementById('userPwd').value = '';
            document.getElementById('userPwd').placeholder = 'Kosongkan jika tidak ingin reset';
            document.getElementById('userPwd').required = false;
            document.getElementById('pwdLabel').textContent = 'Kata sandi baru (opsional)';
            document.getElementById('userRole').value = el.dataset.userRole;
            openModal('userModal');
        }
        async function submitUser(e) {
            e.preventDefault();
            const id = document.getElementById('userId').value;
            const body = { username: document.getElementById('userName').value, role: document.getElementById('userRole').value };
            const pwd = document.getElementById('userPwd').value;
            if (pwd) body.password = pwd;
            if (!id && !pwd) return alert('Kata sandi wajib diisi untuk user baru');
            const url = id ? `/api/users/${id}` : '/api/users';
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await csrfFetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();
                if (res.ok) { location.reload(); } else { alert(data.message); }
            } catch (err) { alert('Error: ' + err.message); }
        }
        function deleteUser(el) {
            var id = el.dataset.userId;
            var name = el.dataset.userName;
            if (!confirm('Yakin hapus user "' + name + '"? Ini tidak bisa dibatalkan.')) return;
            csrfFetch('/api/users/' + id, { method: 'DELETE' }).then(function (r) { return r.json(); }).then(function (d) { if (d.status === 'success') location.reload(); else alert(d.message); }).catch(function (e) { alert(e.message); });
        }
        document.querySelector('[onclick="openModal(\'userModal\')"]')?.addEventListener('click', () => {
            document.getElementById('userModalTitle').textContent = 'User Baru';
            document.getElementById('userId').value = '';
            document.getElementById('userName').value = '';
            document.getElementById('userName').readOnly = false;
            document.getElementById('userPwd').value = '';
            document.getElementById('userPwd').placeholder = 'Masukkan kata sandi';
            document.getElementById('userPwd').required = true;
            document.getElementById('pwdLabel').textContent = 'Kata sandi';
            document.getElementById('userRole').value = 'operator';
        });


        // ── Reset Password ──
        function openResetPwd(el) {
            const id = el.dataset.userId;
            const name = el.dataset.userName;
            document.getElementById('resetPwdUserId').value = id;
            document.getElementById('resetPwdUserName').textContent = name;
            document.getElementById('resetPwdInput').value = '';
            openModal('resetPwdModal');
        }
        async function submitResetPwd() {
            const id = document.getElementById('resetPwdUserId').value;
            const pwd = document.getElementById('resetPwdInput').value;
            if (!pwd || pwd.length < <%= minPasswordLength %>) return alert('Kata sandi minimal <%= minPasswordLength %> karakter');
            try {
                const r = await csrfFetch('/api/users/' + id + '/reset-password', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({new_password: pwd}) });
                const d = await r.json();
                if (d.status === 'success') { alert(d.message); closeModal('resetPwdModal'); }
                else alert('Error: ' + d.message);
            } catch(e) { alert('Gagal: ' + e.message); }
        }

        async function resolveAlert(id) {
            if (!confirm('Tandai alert ini sebagai selesai?')) return;
            try {
                const r = await csrfFetch('/api/alerts/' + id + '/resolve', { method: 'POST' });
                const d = await r.json();
                if (d.status === 'success') location.reload();
                else alert('Error: ' + d.message);
            } catch (e) {
                alert('Gagal resolve alert: ' + e.message);
            }
        }

        async function seedDemoData() {
            if (!confirm('Buat data demo untuk grafik, log, pendapatan, tabel shadow, dan peringatan? Data akan ditambahkan ke database.')) return;
            try {
                const r = await csrfFetch('/api/demo/seed-data', { method: 'POST' });
                const d = await r.json();
                if (d.status === 'success') {
                    alert(d.message + '\\nLog: ' + d.logs_inserted + '\\nBaris pendapatan: ' + d.revenue_inserted);
                    location.reload();
                } else {
                    alert('Error: ' + d.message);
                }
            } catch (e) {
                alert('Gagal seed demo data: ' + e.message);
            }
        }

        // ── Import CSV ──
        async function submitImportCsv() {
            const input = document.getElementById('csvFileInput');
            if (!input.files.length) return alert('Pilih file CSV dulu');
            const form = new FormData();
            form.append('csv_file', input.files[0]);
            const btn = document.getElementById('importCsvBtn');
            btn.disabled = true; btn.textContent = 'Mengimpor...';
            try {
                const r = await csrfFetch('/api/services/import', { method:'POST', body: form });
                const d = await r.json();
                if (d.status === 'success') {
                    alert(d.message + (d.errors.length ? '\n\nError:\n' + d.errors.join('\n') : ''));
                    closeModal('importCsvModal');
                    location.reload();
                } else alert('Error: ' + d.message);
            } catch(e) { alert('Gagal: ' + e.message); }
            finally { btn.disabled = false; btn.textContent = 'Impor'; }
        }
        window.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                const isDark = localStorage.getItem('darkMode') === 'true';
                if (isDark) document.body.classList.add('dark-mode');

                toggle.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                if (window.lucide) lucide.createIcons();

                const newToggle = toggle.cloneNode(true);
                toggle.parentNode.replaceChild(newToggle, toggle);

                newToggle.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const dark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', dark);

                    newToggle.innerHTML = dark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                    if (window.lucide) lucide.createIcons();
                });
            } else {
                if (localStorage.getItem('darkMode') === 'true') {
                    document.body.classList.add('dark-mode');
                }
            }
        });
    </script>

    <!-- Modal Reset Password -->
    <div class="modal-overlay" id="resetPwdModal">
        <div class="modal-dialog">
            <div class="modal-header"><span class="modal-title">Atur Ulang Kata Sandi</span><button class="modal-close" onclick="closeModal('resetPwdModal')">&times;</button></div>
            <input type="hidden" id="resetPwdUserId">
            <p style="color:var(--muted);margin-bottom:16px">Atur ulang kata sandi untuk user: <strong id="resetPwdUserName"></strong></p>
            <div class="form-group"><label class="form-label">Kata Sandi Baru</label><input type="password" id="resetPwdInput" class="form-control" placeholder="Minimal <%= minPasswordLength %> karakter"></div>
            <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('resetPwdModal')">Batal</button><button class="btn btn-primary" onclick="submitResetPwd()"><i data-lucide="key-round"></i> Simpan</button></div>
        </div>
    </div>

    <!-- Modal Import CSV -->
    <div class="modal-overlay" id="importCsvModal">
        <div class="modal-dialog">
            <div class="modal-header"><span class="modal-title">Impor Service dari CSV</span><button class="modal-close" onclick="closeModal('importCsvModal')">&times;</button></div>
            <div class="card-note" style="margin-bottom:12px">Format CSV: <code>nama_service,url_tujuan,health_path,status_aktif</code><br>Contoh: <code>newservice,http://localhost:3007,/health,1</code><br>Kolom health_path boleh dikosongkan atau memakai format lama <code>nama_service,url_tujuan,status_aktif</code>.</div>
            <div class="form-group"><label class="form-label">File CSV</label><input type="file" id="csvFileInput" class="form-control" accept=".csv,.txt"></div>
            <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('importCsvModal')">Batal</button><button id="importCsvBtn" class="btn btn-success" onclick="submitImportCsv()"><i data-lucide="upload"></i> Impor</button></div>
        </div>
    </div>
</body>

</html>
