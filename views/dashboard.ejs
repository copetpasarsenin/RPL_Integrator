                                                        <script id="revenueChartData" type="application/json">{"labels":<%- safeJson(revenueChart.labels) %>,"data":<%- safeJson(revenueChart.data) %>}</script>
                                                        <script>
                                                            window.addEventListener('DOMContentLoaded', function () {
                                                                var d = JSON.parse(document.getElementById('revenueChartData').textContent);
                                                                new Chart(document.getElementById('revChart'), { type: 'line', data: { labels: d.labels, datasets: [{ label: 'Pendapatan', data: d.data, borderColor: '#f59e0b', backgroundColor: 'rgba(245,158,11,0.1)', tension: 0.35, fill: true }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } } });
                                                            });
                                                        </script>

                                                        <!-- API KEYS -->
                                                        <% } else if (section==='apikeys') { %>
                                                            <div style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:12px">
                                                                <div>
                                                                    <div class="page-title">API Keys</div>
                                                                    <div class="page-subtitle">Kelola API Key untuk akses gateway tanpa login. Gunakan prefix <code>igw_</code> sebagai Bearer token.</div>
                                                                </div>
                                                                <button class="btn btn-success" onclick="openModal('newKeyModal')"><i data-lucide="plus"></i> Generate Key Baru</button>
                                                            </div>
                                                            <div class="card" style="margin-top:16px">
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>#</th><th>Nama Key</th><th>User</th><th>Prefix</th><th>Quota Hari Ini</th><th>Status</th><th>Last Used</th><th>Dibuat</th><th>Aksi</th></tr></thead>
                                                                        <tbody>
                                                                        <% apiKeys.forEach(k => { %>
                                                                            <tr>
                                                                                <td style="color:var(--muted)">#<%= k.id %></td>
                                                                                <td><strong><%= k.key_name %></strong></td>
                                                                                <td><%= k.username %></td>
                                                                                <td><code style="font-size:12px"><%= k.api_key_prefix %></code></td>
                                                                                <td><%= k.usage_today || 0 %> / <%= k.daily_limit || 1000 %></td>
                                                                                <td><span class="badge badge-<%= k.is_active ? 'success' : 'warning' %>"><%= k.is_active ? 'Aktif' : 'Revoked' %></span></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= k.last_used ? new Date(k.last_used).toLocaleString('id-ID') : 'Belum digunakan' %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(k.created_at).toLocaleString('id-ID') %></td>
                                                                                <td><% if (k.is_active) { %><button class="btn-icon btn-icon-danger" onclick="revokeKey(<%= k.id %>)" title="Revoke"><i data-lucide="trash-2"></i></button><% } %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (apiKeys.length === 0) { %><tr><td colspan="9" style="text-align:center;padding:32px;color:var(--muted)">Belum ada API Key. Generate key baru untuk mulai.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                            <!-- Modal Generate Key -->
                                                            <div class="modal-overlay" id="newKeyModal">
                                                                <div class="modal-dialog">
                                                                    <div class="modal-header"><span class="modal-title">Generate API Key Baru</span><button class="modal-close" onclick="closeModal('newKeyModal')">&times;</button></div>
                                                                    <div class="form-group"><label class="form-label">Nama Key</label><input type="text" id="newKeyName" class="form-control" placeholder="cth: Production Key, Testing Key..."></div>
                                                                    <div class="form-group"><label class="form-label">Limit Harian</label><input type="number" id="newKeyDailyLimit" class="form-control" min="1" max="100000" value="1000"></div>
                                                                    <div id="newKeyResult" style="margin:12px 0;display:none">
                                                                        <div class="card-note" style="background:#fef08a;color:#713f12;border-color:#fbbf24;font-weight:600">⚠️ Salin API Key berikut sekarang! Tidak akan ditampilkan lagi.</div>
                                                                        <input type="text" id="newKeyValue" class="form-control" readonly style="font-family:monospace;font-size:12px;margin-top:8px">
                                                                        <button class="btn btn-outline" style="width:100%;margin-top:8px" onclick="copyNewKey()"><i data-lucide="copy"></i> Salin Key</button>
                                                                    </div>
                                                                    <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('newKeyModal')">Tutup</button><button class="btn btn-success" onclick="generateApiKey()"><i data-lucide="sparkles"></i> Generate</button></div>
                                                                </div>
                                                            </div>
                                                            <script>
                                                            async function generateApiKey() {
                                                                const name = document.getElementById('newKeyName').value.trim();
                                                                const daily_limit = parseInt(document.getElementById('newKeyDailyLimit').value, 10) || 1000;
                                                                if (!name || name.length < 3) return alert('Nama key minimal 3 karakter');
                                                                try {
                                                                    const r = await csrfFetch('/api/keys', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({key_name: name, daily_limit}) });
                                                                    const d = await r.json();
                                                                    if (d.status === 'success') {
                                                                        document.getElementById('newKeyValue').value = d.api_key;
                                                                        document.getElementById('newKeyResult').style.display = 'block';
                                                                        lucide.createIcons();
                                                                    } else { alert('Error: ' + d.message); }
                                                                } catch(e) { alert('Gagal generate: ' + e.message); }
                                                            }
                                                            async function revokeKey(id) {
                                                                if (!confirm('Yakin revoke API Key ini? Tidak bisa diaktifkan kembali.')) return;
                                                                const r = await csrfFetch('/api/keys/' + id, { method:'DELETE' });
                                                                const d = await r.json();
                                                                if (d.status === 'success') location.reload();
                                                                else alert('Error: ' + d.message);
                                                            }
                                                            function copyNewKey() {
                                                                const el = document.getElementById('newKeyValue');
                                                                el.select();
                                                                navigator.clipboard?.writeText(el.value) || document.execCommand('copy');
                                                                alert('API Key berhasil disalin!');
                                                            }
                                                            </script>

                                                        <!-- AUDIT LOG -->
                                                        <% } else if (section==='audit') { %>
                                                            <div class="page-title">Audit Log</div>
                                                            <div class="page-subtitle">Rekaman semua aksi admin dan operator di sistem.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/audit">
                                                                    <select name="action" class="form-control" style="width:auto">
                                                                        <option value="">Semua Aksi</option>
                                                                        <option value="CREATE_SERVICE" <%=filterAction==='CREATE_SERVICE'?'selected':''%>>Create Service</option>
                                                                        <option value="UPDATE_SERVICE" <%=filterAction==='UPDATE_SERVICE'?'selected':''%>>Update Service</option>
                                                                        <option value="DELETE_SERVICE" <%=filterAction==='DELETE_SERVICE'?'selected':''%>>Delete Service</option>
                                                                        <option value="CREATE_USER" <%=filterAction==='CREATE_USER'?'selected':''%>>Create User</option>
                                                                        <option value="DELETE_USER" <%=filterAction==='DELETE_USER'?'selected':''%>>Delete User</option>
                                                                        <option value="RESET_PASSWORD" <%=filterAction==='RESET_PASSWORD'?'selected':''%>>Reset Password</option>
                                                                        <option value="CREATE_API_KEY" <%=filterAction==='CREATE_API_KEY'?'selected':''%>>Create API Key</option>
                                                                        <option value="REVOKE_API_KEY" <%=filterAction==='REVOKE_API_KEY'?'selected':''%>>Revoke API Key</option>
                                                                        <option value="IMPORT_SERVICES" <%=filterAction==='IMPORT_SERVICES'?'selected':''%>>Import Services</option>
                                                                    </select>
                                                                    <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                                    <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="search"></i> Filter</button>
                                                                    <% if (filterAction || dateStart || dateEnd) { %><a href="/dashboard/audit" class="btn btn-outline">Reset</a><% } %>
                                                                    <a href="/dashboard/audit/export?action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline" style="margin-left:auto"><i data-lucide="download"></i> Export CSV</a>
                                                                </form>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="shield-alert"></i> Audit Log (<%= total %> total)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>#</th><th>Waktu</th><th>User</th><th>Aksi</th><th>Resource</th><th>Detail</th><th>IP</th></tr></thead>
                                                                        <tbody>
                                                                        <% auditLogs.forEach(log => { %>
                                                                            <tr>
                                                                                <td style="color:var(--muted)">#<%= log.id %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(log.created_at).toLocaleString('id-ID') %></td>
                                                                                <td><strong><%= log.username || '-' %></strong></td>
                                                                                <td><span class="badge badge-<%= log.action.includes('DELETE')||log.action.includes('REVOKE') ? 'error' : log.action.includes('CREATE')||log.action.includes('IMPORT') ? 'success' : 'info' %>"><%= log.action %></span></td>
                                                                                <td><%= log.resource || '-' %></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= log.detail || '-' %></td>
                                                                                <td style="font-size:12px"><%= log.ip || '-' %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (auditLogs.length === 0) { %><tr><td colspan="7" style="text-align:center;padding:32px;color:var(--muted)">Belum ada audit log.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                                <% if (totalPages > 1) { %>
                                                                <div style="padding:16px;display:flex;gap:8px;justify-content:center;border-top:1px solid var(--border)">
                                                                    <% if (page > 1) { %><a href="/dashboard/audit?page=<%= page-1 %>&action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline btn-sm">Prev</a><% } %>
                                                                    <span style="color:var(--muted);font-size:14px">Page <%= page %> of <%= totalPages %></span>
                                                                    <% if (page < totalPages) { %><a href="/dashboard/audit?page=<%= page+1 %>&action=<%= filterAction %>&start=<%= dateStart || '' %>&end=<%= dateEnd || '' %>" class="btn btn-outline btn-sm">Next</a><% } %>
                                                                </div>
                                                                <% } %>
                                                            </div>

                                                        <!-- HEALTH HISTORY -->
                                                        <% } else if (section==='health_history') { %>
                                                            <div class="page-title">Service Health History</div>
                                                            <div class="page-subtitle">Rekaman status Online/Down setiap service dalam 24 jam terakhir (dicek setiap 1 menit).</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/health-history">
                                                                    <input type="date" name="start" class="form-control" value="<%= dateStart || '' %>" style="width:auto">
                                                                    <input type="date" name="end" class="form-control" value="<%= dateEnd || '' %>" style="width:auto">
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                                                    <a href="/dashboard/health-history" class="btn btn-outline">Reset</a>
                                                                </form>
                                                            </div>
                                                            <div class="stats-grid">
                                                            <% services.forEach(svc => { const s = summary[svc] || {online:0,down:0}; const total = s.online + s.down; const pct = total > 0 ? Math.round((s.online/total)*100) : 0; %>
                                                                <div class="stat-box <%= pct >= 90 ? 'stat-green' : pct >= 50 ? 'stat-amber' : 'stat-red' %>">
                                                                    <div>
                                                                        <div class="stat-title"><%= svc %></div>
                                                                        <div class="stat-value"><%= pct %>%</div>
                                                                        <div class="stat-desc">Uptime 24 jam &bull; <span style="color:#86efac"><%= s.online %> Online</span> / <span style="color:#fca5a5"><%= s.down %> Down</span></div>
                                                                    </div>
                                                                    <div class="stat-icon"><i data-lucide="<%= pct >= 90 ? 'check-circle' : pct >= 50 ? 'alert-circle' : 'x-circle' %>"></i></div>
                                                                </div>
                                                            <% }) %>
                                                            <% if (services.length === 0) { %>
                                                                <div class="card" style="grid-column:1/-1;text-align:center;padding:32px;color:var(--muted)">Belum ada data health history. Tunggu health check berjalan (setiap 1 menit).</div>
                                                            <% } %>
                                                            </div>
                                                            <div class="card" style="margin-top:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="activity"></i> Log Terbaru (24 jam)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Status</th><th>Waktu Check</th></tr></thead>
                                                                        <tbody>
                                                                        <% healthLogs.slice().reverse().slice(0,50).forEach(log => { %>
                                                                            <tr>
                                                                                <td><strong><%= log.service_name %></strong></td>
                                                                                <td><span class="badge badge-<%= log.status==='Online'?'success':'error' %>"><%= log.status %></span></td>
                                                                                <td style="font-size:12px;color:var(--muted)"><%= new Date(log.checked_at).toLocaleString('id-ID') %></td>
                                                                            </tr>
                                                                        <% }) %>
                                                                        <% if (healthLogs.length === 0) { %><tr><td colspan="3" style="text-align:center;padding:24px;color:var(--muted)">Belum ada data.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } else if (section==='alerts') { %>
                                                            <div class="page-title">System Alerts</div>
                                                            <div class="page-subtitle">Incident feed otomatis dari health monitoring dan aksi operasional gateway.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <form class="filter-bar" method="GET" action="/dashboard/alerts">
                                                                    <select name="status" class="form-control" style="width:auto">
                                                                        <option value="open" <%= alertStatus === 'open' ? 'selected' : '' %>>Open</option>
                                                                        <option value="resolved" <%= alertStatus === 'resolved' ? 'selected' : '' %>>Resolved</option>
                                                                        <option value="all" <%= alertStatus === 'all' ? 'selected' : '' %>>All</option>
                                                                    </select>
                                                                    <button class="btn btn-primary" type="submit"><i data-lucide="filter"></i> Filter</button>
                                                                </form>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="bell-ring"></i> Alerts (<%= total %> total)</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>#</th><th>Severity</th><th>Source</th><th>Title</th><th>Message</th><th>Status</th><th>Created</th><th>Action</th></tr></thead>
                                                                        <tbody>
                                                                            <% alerts.forEach(a => { %>
                                                                                <tr>
                                                                                    <td style="color:var(--muted)">#<%= a.id %></td>
                                                                                    <td><span class="badge badge-<%= a.severity === 'critical' ? 'error' : a.severity === 'warning' ? 'warning' : 'info' %>"><%= a.severity %></span></td>
                                                                                    <td><code><%= a.source %></code></td>
                                                                                    <td><strong><%= a.title %></strong></td>
                                                                                    <td style="font-size:12px;color:var(--muted)"><%= a.message || '-' %></td>
                                                                                    <td><span class="badge badge-<%= a.is_resolved ? 'success' : 'error' %>"><%= a.is_resolved ? 'Resolved' : 'Open' %></span></td>
                                                                                    <td style="font-size:12px;color:var(--muted)"><%= new Date(a.created_at).toLocaleString('id-ID') %></td>
                                                                                    <td><% if (!a.is_resolved) { %><button class="btn btn-outline btn-sm" onclick="resolveAlert(<%= a.id %>)"><i data-lucide="check-circle"></i> Resolve</button><% } %></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                            <% if (alerts.length === 0) { %><tr><td colspan="8" style="text-align:center;padding:32px;color:var(--muted)">Tidak ada alert.</td></tr><% } %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                                <% if (totalPages > 1) { %>
                                                                    <div class="pagination">
                                                                        <% if (page > 1) { %><a href="/dashboard/alerts?page=<%= page - 1 %>&status=<%= alertStatus %>" class="btn btn-outline btn-sm">Prev</a><% } %>
                                                                        <span style="color:var(--muted);font-size:14px">Page <%= page %> of <%= totalPages %></span>
                                                                        <% if (page < totalPages) { %><a href="/dashboard/alerts?page=<%= page + 1 %>&status=<%= alertStatus %>" class="btn btn-outline btn-sm">Next</a><% } %>
                                                                    </div>
                                                                <% } %>
                                                            </div>
                                                        <% } else if (section==='architecture') { %>
                                                            <div class="page-title">System Architecture</div>
                                                            <div class="page-subtitle">Peta modul, alur request, dan service ekosistem yang digunakan gateway.</div>
                                                            <div class="plugin-grid" style="margin-bottom:16px">
                                                                <% modules.forEach(m => { %>
                                                                    <div class="plugin-card">
                                                                        <div class="plugin-header"><div class="plugin-icon"><i data-lucide="<%= m.icon %>"></i></div><span class="badge badge-success">Active</span></div>
                                                                        <div class="plugin-name"><%= m.name %></div>
                                                                        <div class="plugin-desc"><%= m.desc %></div>
                                                                    </div>
                                                                <% }) %>
                                                            </div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="workflow"></i> Request Flow</div></div>
                                                                <div style="display:grid;gap:10px">
                                                                    <% flows.forEach((f, i) => { %>
                                                                        <div style="display:flex;gap:12px;align-items:flex-start;padding:10px;border:1px solid var(--border);border-radius:8px;background:var(--surface)">
                                                                            <span class="badge badge-info"><%= i + 1 %></span>
                                                                            <div><%= f %></div>
                                                                        </div>
                                                                    <% }) %>
                                                                </div>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="network"></i> Service Topology</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Gateway Route</th><th>Target URL</th><th>Health</th><th>Status</th></tr></thead>
                                                                        <tbody>
                                                                            <% services.forEach(s => { %>
                                                                                <tr>
                                                                                    <td><strong><%= s.nama_service %></strong></td>
                                                                                    <td><code>/integrator/<%= s.nama_service %>/{path}</code></td>
                                                                                    <td><code><%= s.url_tujuan %></code></td>
                                                                                    <td><code><%= s.health_path || '/' %></code></td>
                                                                                    <td><span class="badge badge-<%= s.status_aktif ? 'success' : 'warning' %>"><%= s.status_aktif ? 'Active' : 'Inactive' %></span></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } else if (section==='docs') { %>
                                                            <div class="page-title">API Documentation</div>
                                                            <div class="page-subtitle">Referensi endpoint gateway, format autentikasi, dan route service dinamis.</div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="key-round"></i> Authentication</div></div>
                                                                <div class="card-note">Gunakan header <code>Authorization: Bearer &lt;JWT atau API Key igw_...&gt;</code>. JWT bisa dibuat dari API Simulator, sedangkan API Key dikelola dari menu API Keys.</div>
                                                            </div>
                                                            <div class="card" style="margin-bottom:16px">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="book-open"></i> Endpoint Utama</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Method</th><th>Path</th><th>Auth</th><th>Deskripsi</th></tr></thead>
                                                                        <tbody>
                                                                            <% docs.forEach(d => { %>
                                                                                <tr>
                                                                                    <td><span class="badge badge-info"><%= d.method %></span></td>
                                                                                    <td><code><%= d.path %></code></td>
                                                                                    <td><%= d.auth %></td>
                                                                                    <td><%= d.desc %></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                            <div class="card">
                                                                <div class="card-header"><div class="card-title"><i data-lucide="route"></i> Route Dinamis dari Database</div></div>
                                                                <div class="table-wrapper">
                                                                    <table>
                                                                        <thead><tr><th>Service</th><th>Gateway URL</th><th>Target URL</th><th>Health Path</th><th>Status</th></tr></thead>
                                                                        <tbody>
                                                                            <% services.forEach(s => { %>
                                                                                <tr>
                                                                                    <td><strong><%= s.nama_service %></strong></td>
                                                                                    <td><code>/integrator/<%= s.nama_service %>/{path}</code></td>
                                                                                    <td><code><%= s.url_tujuan %>/{path}</code></td>
                                                                                    <td><code><%= s.health_path || '/' %></code></td>
                                                                                    <td><span class="badge badge-<%= s.status_aktif ? 'success' : 'warning' %>"><%= s.status_aktif ? 'Aktif' : 'Nonaktif' %></span></td>
                                                                                </tr>
                                                                            <% }) %>
                                                                        </tbody>
                                                                    </table>
                                                                </div>
                                                            </div>
                                                        <% } %>
        </div>
    </div>

    <!-- ═══ GLOBAL SCRIPTS ═══ -->
    <script>
        window.CSRF_TOKEN = document.querySelector('meta[name="csrf-token"]')?.content || '';
        function csrfFetch(url, options) {
            const finalOptions = options || {};
            finalOptions.headers = Object.assign({}, finalOptions.headers || {}, { 'X-CSRF-Token': window.CSRF_TOKEN });
            return fetch(url, finalOptions);
        }
        function openModal(id) { document.getElementById(id).classList.add('active'); }
        function closeModal(id) { document.getElementById(id).classList.remove('active'); }

        // ── Services CRUD ──
        function editService(el) {
            document.getElementById('serviceModalTitle').textContent = 'Edit Service';
            document.getElementById('svcId').value = el.dataset.svcId;
            document.getElementById('svcName').value = el.dataset.svcName;
            document.getElementById('svcUrl').value = el.dataset.svcUrl;
            document.getElementById('svcHealthPath').value = el.dataset.svcHealth || '/';
            document.getElementById('svcStatus').value = el.dataset.svcStatus;
            document.getElementById('svcName').readOnly = true;
            openModal('serviceModal');
        }
        async function submitService(e) {
            e.preventDefault();
            const id = document.getElementById('svcId').value;
            const body = {
                nama_service: document.getElementById('svcName').value,
                url_tujuan: document.getElementById('svcUrl').value,
                health_path: document.getElementById('svcHealthPath').value || '/',
                status_aktif: parseInt(document.getElementById('svcStatus').value)
            };
            const url = id ? `/api/services/${id}` : '/api/services';
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await csrfFetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();
                if (res.ok) { location.reload(); } else { alert(data.message); }
            } catch (err) { alert('Error: ' + err.message); }
        }
        function deleteService(el) {
            var id = el.dataset.svcId;
            var name = el.dataset.svcName;
            if (!confirm('Yakin hapus service "' + name + '"? Ini tidak bisa dibatalkan.')) return;
            csrfFetch('/api/services/' + id, { method: 'DELETE' }).then(function (r) { return r.json(); }).then(function (d) { if (d.status === 'success') location.reload(); else alert(d.message); }).catch(function (e) { alert(e.message); });
        }
        async function testService(el) {
            const id = el.dataset.svcId;
            el.disabled = true;
            try {
                const r = await csrfFetch('/api/services/' + id + '/test', { method: 'POST' });
                const d = await r.json();
                if (r.ok) alert('Health check: ' + d.health_status + '\\nHTTP: ' + d.http_status + '\\nLatency: ' + d.latency_ms + 'ms\\nURL: ' + d.health_url);
                else alert('Service Down\\n' + (d.message || 'Tidak bisa dihubungi') + '\\nURL: ' + (d.health_url || '-'));
                location.reload();
            } catch (e) {
                alert('Gagal test service: ' + e.message);
            } finally {
                el.disabled = false;
            }
        }
        // Reset service modal on open for "New"
        document.querySelector('[onclick="openModal(\'serviceModal\')"]')?.addEventListener('click', () => {
            document.getElementById('serviceModalTitle').textContent = 'New Service';
            document.getElementById('svcId').value = '';
            document.getElementById('svcName').value = '';
            document.getElementById('svcUrl').value = '';
            document.getElementById('svcHealthPath').value = '/';
            document.getElementById('svcStatus').value = '1';
            document.getElementById('svcName').readOnly = false;
        });

        // ── Users CRUD ──
        function editUser(el) {
            document.getElementById('userModalTitle').textContent = 'Edit User';
            document.getElementById('userId').value = el.dataset.userId;
            document.getElementById('userName').value = el.dataset.userName;
            document.getElementById('userName').readOnly = true;
            document.getElementById('userPwd').value = '';
            document.getElementById('userPwd').placeholder = 'Kosongkan jika tidak ingin reset';
            document.getElementById('userPwd').required = false;
            document.getElementById('pwdLabel').textContent = 'Password Baru (opsional)';
            document.getElementById('userRole').value = el.dataset.userRole;
            openModal('userModal');
        }
        async function submitUser(e) {
            e.preventDefault();
            const id = document.getElementById('userId').value;
            const body = { username: document.getElementById('userName').value, role: document.getElementById('userRole').value };
            const pwd = document.getElementById('userPwd').value;
            if (pwd) body.password = pwd;
            if (!id && !pwd) return alert('Password wajib diisi untuk user baru');
            const url = id ? `/api/users/${id}` : '/api/users';
            const method = id ? 'PUT' : 'POST';
            try {
                const res = await csrfFetch(url, { method, headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(body) });
                const data = await res.json();
                if (res.ok) { location.reload(); } else { alert(data.message); }
            } catch (err) { alert('Error: ' + err.message); }
        }
        function deleteUser(el) {
            var id = el.dataset.userId;
            var name = el.dataset.userName;
            if (!confirm('Yakin hapus user "' + name + '"? Ini tidak bisa dibatalkan.')) return;
            csrfFetch('/api/users/' + id, { method: 'DELETE' }).then(function (r) { return r.json(); }).then(function (d) { if (d.status === 'success') location.reload(); else alert(d.message); }).catch(function (e) { alert(e.message); });
        }
        document.querySelector('[onclick="openModal(\'userModal\')"]')?.addEventListener('click', () => {
            document.getElementById('userModalTitle').textContent = 'New User';
            document.getElementById('userId').value = '';
            document.getElementById('userName').value = '';
            document.getElementById('userName').readOnly = false;
            document.getElementById('userPwd').value = '';
            document.getElementById('userPwd').placeholder = 'Masukkan password';
            document.getElementById('userPwd').required = true;
            document.getElementById('pwdLabel').textContent = 'Password';
            document.getElementById('userRole').value = 'operator';
        });


        // ── Reset Password ──
        function openResetPwd(el) {
            const id = el.dataset.userId;
            const name = el.dataset.userName;
            document.getElementById('resetPwdUserId').value = id;
            document.getElementById('resetPwdUserName').textContent = name;
            document.getElementById('resetPwdInput').value = '';
            openModal('resetPwdModal');
        }
        async function submitResetPwd() {
            const id = document.getElementById('resetPwdUserId').value;
            const pwd = document.getElementById('resetPwdInput').value;
            if (!pwd || pwd.length < <%= minPasswordLength %>) return alert('Password minimal <%= minPasswordLength %> karakter');
            try {
                const r = await csrfFetch('/api/users/' + id + '/reset-password', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({new_password: pwd}) });
                const d = await r.json();
                if (d.status === 'success') { alert(d.message); closeModal('resetPwdModal'); }
                else alert('Error: ' + d.message);
            } catch(e) { alert('Gagal: ' + e.message); }
        }

        async function resolveAlert(id) {
            if (!confirm('Tandai alert ini sebagai selesai?')) return;
            try {
                const r = await csrfFetch('/api/alerts/' + id + '/resolve', { method: 'POST' });
                const d = await r.json();
                if (d.status === 'success') location.reload();
                else alert('Error: ' + d.message);
            } catch (e) {
                alert('Gagal resolve alert: ' + e.message);
            }
        }

        async function seedDemoData() {
            if (!confirm('Buat data demo untuk grafik, logs, revenue, dan alerts? Data akan ditambahkan ke database.')) return;
            try {
                const r = await csrfFetch('/api/demo/seed-data', { method: 'POST' });
                const d = await r.json();
                if (d.status === 'success') {
                    alert(d.message + '\\nLogs: ' + d.logs_inserted + '\\nRevenue rows: ' + d.revenue_inserted);
                    location.reload();
                } else {
                    alert('Error: ' + d.message);
                }
            } catch (e) {
                alert('Gagal seed demo data: ' + e.message);
            }
        }

        // ── Import CSV ──
        async function submitImportCsv() {
            const input = document.getElementById('csvFileInput');
            if (!input.files.length) return alert('Pilih file CSV dulu');
            const form = new FormData();
            form.append('csv_file', input.files[0]);
            const btn = document.getElementById('importCsvBtn');
            btn.disabled = true; btn.textContent = 'Mengimport...';
            try {
                const r = await csrfFetch('/api/services/import', { method:'POST', body: form });
                const d = await r.json();
                if (d.status === 'success') {
                    alert(d.message + (d.errors.length ? '\n\nError:\n' + d.errors.join('\n') : ''));
                    closeModal('importCsvModal');
                    location.reload();
                } else alert('Error: ' + d.message);
            } catch(e) { alert('Gagal: ' + e.message); }
            finally { btn.disabled = false; btn.textContent = 'Import'; }
        }
        window.addEventListener('DOMContentLoaded', () => {
            lucide.createIcons();

            const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                const isDark = localStorage.getItem('darkMode') === 'true';
                if (isDark) document.body.classList.add('dark-mode');

                toggle.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                if (window.lucide) lucide.createIcons();

                const newToggle = toggle.cloneNode(true);
                toggle.parentNode.replaceChild(newToggle, toggle);

                newToggle.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const dark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', dark);

                    newToggle.innerHTML = dark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                    if (window.lucide) lucide.createIcons();
                });
            } else {
                if (localStorage.getItem('darkMode') === 'true') {
                    document.body.classList.add('dark-mode');
                }
            }
        });
    </script>

    <!-- Modal Reset Password -->
    <div class="modal-overlay" id="resetPwdModal">
        <div class="modal-dialog">
            <div class="modal-header"><span class="modal-title">Reset Password</span><button class="modal-close" onclick="closeModal('resetPwdModal')">&times;</button></div>
            <input type="hidden" id="resetPwdUserId">
            <p style="color:var(--muted);margin-bottom:16px">Reset password untuk user: <strong id="resetPwdUserName"></strong></p>
            <div class="form-group"><label class="form-label">Password Baru</label><input type="password" id="resetPwdInput" class="form-control" placeholder="Minimal <%= minPasswordLength %> karakter"></div>
            <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('resetPwdModal')">Batal</button><button class="btn btn-primary" onclick="submitResetPwd()"><i data-lucide="key-round"></i> Reset</button></div>
        </div>
    </div>

    <!-- Modal Import CSV -->
    <div class="modal-overlay" id="importCsvModal">
        <div class="modal-dialog">
            <div class="modal-header"><span class="modal-title">Import Services dari CSV</span><button class="modal-close" onclick="closeModal('importCsvModal')">&times;</button></div>
            <div class="card-note" style="margin-bottom:12px">Format CSV: <code>nama_service,url_tujuan,health_path,status_aktif</code><br>Contoh: <code>newservice,http://localhost:3007,/health,1</code><br>Kolom health_path boleh dikosongkan atau memakai format lama <code>nama_service,url_tujuan,status_aktif</code>.</div>
            <div class="form-group"><label class="form-label">File CSV</label><input type="file" id="csvFileInput" class="form-control" accept=".csv,.txt"></div>
            <div class="modal-footer"><button class="btn btn-outline" onclick="closeModal('importCsvModal')">Batal</button><button id="importCsvBtn" class="btn btn-success" onclick="submitImportCsv()"><i data-lucide="upload"></i> Import</button></div>
        </div>
    </div>
</body>

</html>
