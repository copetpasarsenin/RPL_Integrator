<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - Gateway Integrator</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/lucide@latest"></script>
</head>

<body>
    <div class="sidebar">
        <div class="sidebar-header">
            <div class="brand-logo">IG</div>
            <div>
                <div class="brand-title">Gateway Integrator</div>
                <div class="brand-subtitle">API Gateway Integrator</div>
            </div>
        </div>
        <div class="sidebar-menu">
            <div class="menu-group">Workspace</div>
            <a href="javascript:void(0)" onclick="showSection('overview')" id="menu-overview" class="menu-item active">
                <span class="menu-icon"><i data-lucide="layout-dashboard"></i></span> Overview
            </a>
            <a href="/client-portal" class="menu-item">
                <span class="menu-icon"><i data-lucide="zap"></i></span> API Simulator
            </a>

            <div class="menu-group">Gateway Services</div>
            <a href="javascript:void(0)" onclick="showSection('services')" id="menu-services" class="menu-item">
                <span class="menu-icon"><i data-lucide="server"></i></span> Services (<%= services.length %>)
            </a>
            <a href="javascript:void(0)" onclick="showSection('routes')" id="menu-routes" class="menu-item">
                <span class="menu-icon"><i data-lucide="route"></i></span> Routes
            </a>
            <a href="/api/logs" class="menu-item" target="_blank">
                <span class="menu-icon"><i data-lucide="clipboard-list"></i></span> Request Logs
            </a>

            <div class="menu-group">System</div>
            <a href="/api/status" class="menu-item" target="_blank">
                <span class="menu-icon"><i data-lucide="activity"></i></span> System Status
            </a>
        </div>
    </div>

    <div class="main-wrapper">
        <div class="topbar">
            <div class="breadcrumb">
                <a href="/">Home</a>
                <i data-lucide="chevron-right"></i>
                <a href="#">Gateway System</a>
                <i data-lucide="chevron-right"></i>
                <span id="breadcrumb-current" style="color: var(--ink); font-weight: 700;">Overview</span>
            </div>
            <div class="topbar-actions">
                <span class="user-pill"><i data-lucide="user-round"></i><%= currentUser.username %> (<%= currentUser.role %>)</span>
                <a href="/client-portal" class="btn btn-outline"><i data-lucide="key-round"></i> Generate Token</a>
                <form class="logout-form" method="POST" action="/logout">
                    <button class="btn btn-outline"><i data-lucide="log-out"></i> Logout</button>
                </form>
            </div>
        </div>

        <div class="content">
            <div class="page-title" id="content-title">Overview</div>
            <div class="page-subtitle">Pantau trafik gateway, status service, dan pendapatan integrasi berdasarkan role pengguna.</div>

            <div id="overview-section">
                <div class="stats-grid">
                    <% if (canViewRevenue) { %>
                        <div class="stat-box stat-amber">
                            <div>
                                <div class="stat-title">Pendapatan Gateway</div>
                                <div class="stat-value">Rp <%= totalRevenue.toLocaleString('id-ID') %></div>
                                <div class="stat-desc">Total fee dari revenue_logs</div>
                            </div>
                            <div class="stat-icon"><i data-lucide="coins"></i></div>
                        </div>
                    <% } %>
                    <div class="stat-box stat-blue">
                        <div>
                            <div class="stat-title">Total Requests</div>
                            <div class="stat-value"><%= totalRequests %></div>
                            <div class="stat-desc">Jumlah request gateway</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="bar-chart-3"></i></div>
                    </div>
                    <div class="stat-box stat-green">
                        <div>
                            <div class="stat-title">Sukses</div>
                            <div class="stat-value"><%= totalSuccess %></div>
                            <div class="stat-desc">Request berhasil diteruskan</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="check-circle-2"></i></div>
                    </div>
                    <div class="stat-box stat-red">
                        <div>
                            <div class="stat-title">Error</div>
                            <div class="stat-value"><%= totalError %></div>
                            <div class="stat-desc">Gagal atau service offline</div>
                        </div>
                        <div class="stat-icon"><i data-lucide="alert-triangle"></i></div>
                    </div>
                </div>

                <div class="chart-grid <%= canViewRevenue ? '' : 'single' %>">
                    <div class="card">
                        <div class="card-header">
                            <div class="card-title"><i data-lucide="bar-chart-3"></i> Grafik Request API per Layanan</div>
                        </div>
                        <div class="chart-box">
                            <canvas id="requestChart"></canvas>
                        </div>
                    </div>
                    <% if (canViewRevenue) { %>
                        <div class="card">
                            <div class="card-header">
                                <div class="card-title"><i data-lucide="line-chart"></i> Grafik Pendapatan</div>
                            </div>
                            <div class="chart-box">
                                <canvas id="revenueChart"></canvas>
                            </div>
                        </div>
                    <% } %>
                </div>

                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i data-lucide="clipboard-list"></i> Recent Traffic Logs</div>
                        <button class="btn btn-outline" onclick="location.reload()"><i data-lucide="refresh-cw"></i> Refresh</button>
                    </div>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>#</th>
                                    <th>Waktu</th>
                                    <th>IP & User</th>
                                    <th>Metode</th>
                                    <th>Service</th>
                                    <th>Endpoint / Route</th>
                                    <th>Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (logs.length === 0) { %>
                                    <tr>
                                        <td colspan="7" style="text-align: center; padding: 40px; color: var(--muted);">
                                            Belum ada aktivitas terekam.
                                        </td>
                                    </tr>
                                <% } else { %>
                                    <% logs.forEach((log) => { %>
                                        <tr>
                                            <td style="color: var(--muted);">#<%= log.id %></td>
                                            <td style="color: var(--muted); font-size: 12px;"><%= log.waktu %></td>
                                            <td>
                                                <div style="font-weight: 500;"><%= log.user_id || '-' %></div>
                                                <div style="font-size: 11px; color: var(--muted);"><%= log.ip || '-' %></div>
                                            </td>
                                            <td><span class="badge badge-info"><%= log.metode %></span></td>
                                            <td><%= log.service_tujuan || '-' %></td>
                                            <td style="font-family: monospace; font-size: 12px; font-weight: 600;"><%= log.url_tujuan %></td>
                                            <td>
                                                <% if (log.status === 'SUCCESS') { %>
                                                    <span class="badge badge-success">Success</span>
                                                <% } else if (log.status === 'ERROR') { %>
                                                    <span class="badge badge-error">Error</span>
                                                <% } else if (log.status === 'FORWARDED') { %>
                                                    <span class="badge badge-info">Forwarded</span>
                                                <% } else { %>
                                                    <span class="badge badge-warning">Pending</span>
                                                <% } %>
                                            </td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="services-section" style="display: none;">
                <div class="card">
                        <div class="card-header">
                        <div class="card-title"><i data-lucide="server"></i> Registered Services</div>
                    </div>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>ID</th>
                                    <th>Service Name</th>
                                    <th>Target URL</th>
                                    <th>Status</th>
                                    <th>Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (services.length === 0) { %>
                                    <tr>
                                        <td colspan="5" style="text-align:center; padding: 32px; color: var(--muted);">Belum ada service terdaftar.</td>
                                    </tr>
                                <% } else { %>
                                    <% services.forEach((service) => { %>
                                        <tr>
                                            <td>#<%= service.id %></td>
                                            <td><strong><%= service.nama_service %></strong></td>
                                            <td><code><%= service.url_tujuan %></code></td>
                                            <td>
                                                <% if (service.status_aktif) { %>
                                                    <span class="badge badge-success">Active</span>
                                                <% } else { %>
                                                    <span class="badge badge-error">Inactive</span>
                                                <% } %>
                                            </td>
                                            <td style="color: var(--muted); font-size: 12px;"><%= service.updated_at ? new Date(service.updated_at).toLocaleString('id-ID') : '-' %></td>
                                        </tr>
                                    <% }) %>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div id="routes-section" style="display: none;">
                <div class="card">
                    <div class="card-header">
                        <div class="card-title"><i data-lucide="route"></i> Dynamic Gateway Routes</div>
                    </div>
                    <div class="table-wrapper">
                        <table>
                            <thead>
                                <tr>
                                    <th>Gateway Pattern</th>
                                    <th>Target Rule</th>
                                    <th>Auth</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% services.forEach((service) => { %>
                                    <tr>
                                        <td><code>/integrator/<%= service.nama_service %>/{path}</code></td>
                                        <td><code><%= service.url_tujuan %>/{path}</code></td>
                                        <td><span class="badge badge-success">JWT Bearer</span></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const requestChartLabels = <%- JSON.stringify(requestChart.labels) %>;
        const requestChartData = <%- JSON.stringify(requestChart.data) %>;
        const revenueChartLabels = <%- JSON.stringify(revenueChart.labels) %>;
        const revenueChartData = <%- JSON.stringify(revenueChart.data) %>;

        function renderCharts() {
            new Chart(document.getElementById('requestChart'), {
                type: 'bar',
                data: {
                    labels: requestChartLabels,
                    datasets: [{
                        label: 'Total Request',
                        data: requestChartData,
                        backgroundColor: '#3b82f6',
                        borderRadius: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
                }
            });

            <% if (canViewRevenue) { %>
                new Chart(document.getElementById('revenueChart'), {
                    type: 'line',
                    data: {
                        labels: revenueChartLabels,
                        datasets: [{
                            label: 'Pendapatan',
                            data: revenueChartData,
                            borderColor: '#f59e0b',
                            backgroundColor: 'rgba(245, 158, 11, 0.16)',
                            tension: 0.35,
                            fill: true
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { display: false } },
                        scales: { y: { beginAtZero: true } }
                    }
                });
            <% } %>
        }

        function showSection(sectionName) {
            document.getElementById('overview-section').style.display = 'none';
            document.getElementById('services-section').style.display = 'none';
            document.getElementById('routes-section').style.display = 'none';

            document.getElementById('menu-overview').classList.remove('active');
            document.getElementById('menu-services').classList.remove('active');
            document.getElementById('menu-routes').classList.remove('active');

            if (sectionName === 'overview') {
                document.getElementById('overview-section').style.display = 'block';
                document.getElementById('menu-overview').classList.add('active');
                document.getElementById('content-title').innerText = 'Overview';
                document.getElementById('breadcrumb-current').innerText = 'Overview';
            } else if (sectionName === 'services') {
                document.getElementById('services-section').style.display = 'block';
                document.getElementById('menu-services').classList.add('active');
                document.getElementById('content-title').innerText = 'Registered Services';
                document.getElementById('breadcrumb-current').innerText = 'Services';
            } else if (sectionName === 'routes') {
                document.getElementById('routes-section').style.display = 'block';
                document.getElementById('menu-routes').classList.add('active');
                document.getElementById('content-title').innerText = 'Gateway Routing Map';
                document.getElementById('breadcrumb-current').innerText = 'Routes';
            }
        }

        window.addEventListener('DOMContentLoaded', renderCharts);
        window.addEventListener('DOMContentLoaded', () => lucide.createIcons());
    </script>
</body>

</html>
