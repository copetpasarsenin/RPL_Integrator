                                                                            <td><strong>
                                                                                    <%= r.service %>
                                                                                </strong></td>
                                                                            <td>Rp <%=
                                                                                    parseFloat(r.total_fee).toLocaleString('id-ID')
                                                                                    %>
                                                                            </td>
                                                                            <td>
                                                                                <%= r.transactions %>
                                                                            </td>
                                                                        </tr>
                                                                        <% }) %>
                                                                </tbody>
                                                            </table>
                                                        </div>
                                                    </div>
