<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gateway Integrator - Ekosistem UMKM</title>
    <meta name="description" content="API Gateway / Integrator - Middleware pengendali ekosistem ekonomi UMKM. Kelompok 7 RPL 2 ULBI.">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/kong-theme.css">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <script src="https://unpkg.com/lucide@latest"></script>
    <style>
        .hero-container {
            width: min(100%, 1120px);
            padding: 68px 28px 36px;
            color: #ffffff;
        }

        .hero-top {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 8px 12px;
            border-radius: 999px;
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.14);
            color: #bfdbfe;
            font-size: 13px;
            font-weight: 800;
            margin-bottom: 24px;
        }

        .hero-title {
            max-width: 820px;
            font-size: 56px;
            line-height: 1.02;
            font-weight: 850;
            margin-bottom: 18px;
        }

        .hero-subtitle {
            max-width: 700px;
            font-size: 17px;
            color: #bfd0e2;
            margin-bottom: 34px;
            line-height: 1.7;
        }

        .features-grid {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 16px;
            margin: 46px 0 0;
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.08);
            border: 1px solid rgba(255, 255, 255, 0.13);
            border-radius: var(--radius);
            padding: 20px;
            backdrop-filter: blur(10px);
            transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
            animation: fadeInUp 0.5s ease both;
        }

        .feature-card:nth-child(1) { animation-delay: 0.3s; }
        .feature-card:nth-child(2) { animation-delay: 0.4s; }
        .feature-card:nth-child(3) { animation-delay: 0.5s; }
        .feature-card:nth-child(4) { animation-delay: 0.6s; }
        .feature-card:nth-child(5) { animation-delay: 0.7s; }
        .feature-card:nth-child(6) { animation-delay: 0.8s; }

        .feature-card:hover {
            background: rgba(255, 255, 255, 0.14);
            border-color: rgba(255, 255, 255, 0.24);
            transform: translateY(-4px);
            box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
        }

        .feature-icon {
            width: 38px;
            height: 38px;
            display: flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            color: #67e8f9;
            background: rgba(8, 145, 178, 0.18);
            margin-bottom: 14px;
            transition: transform 0.3s ease, background 0.3s ease;
        }

        .feature-card:hover .feature-icon {
            transform: scale(1.15) rotate(-5deg);
            background: rgba(8, 145, 178, 0.3);
        }

        .feature-title {
            font-size: 15px;
            font-weight: 800;
            margin-bottom: 8px;
        }

        .feature-desc {
            font-size: 13px;
            color: #b6c7da;
        }

        .action-buttons {
            display: flex;
            flex-wrap: wrap;
            gap: 14px;
        }

        .btn-outline-light {
            border-color: rgba(255, 255, 255, 0.22);
            color: #ffffff;
            background: rgba(255, 255, 255, 0.08);
        }

        .btn-outline-light:hover {
            background: rgba(255, 255, 255, 0.14);
            color: #ffffff;
            border-color: rgba(255, 255, 255, 0.32);
        }

        .stack-strip {
            margin-top: 42px;
            padding: 18px;
            border: 1px solid rgba(255, 255, 255, 0.12);
            border-radius: var(--radius);
            background: rgba(255, 255, 255, 0.055);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 18px;
            flex-wrap: wrap;
        }

        .stack-title {
            color: #cbd5e1;
            font-size: 13px;
            font-weight: 800;
        }

        .stack-list {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .stack-pill {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            color: #dbeafe;
            font-weight: 700;
            font-size: 13px;
            background: rgba(255, 255, 255, 0.07);
            padding: 8px 12px;
            border-radius: 999px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        @media (max-width: 900px) {
            .hero-title {
                font-size: 40px;
            }

            .features-grid {
                grid-template-columns: repeat(2, minmax(0, 1fr));
            }
        }

        @media (max-width: 560px) {
            .features-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>

<body class="no-sidebar">
    <div style="position:absolute;top:24px;right:24px;z-index:999"><button class="btn btn-outline" id="darkModeToggle" title="Ubah Mode Gelap" style="border-radius: 50%; padding: 8px; width: 38px; height: 38px; display: flex; align-items: center; justify-content: center;"><i data-lucide="moon"></i></button></div>
    <div class="hero-container">
        <div class="hero-top" style="animation: fadeInUp 0.5s ease both;"><i data-lucide="network"></i> RPL Integrator</div>
        <h1 class="hero-title" style="animation: fadeInUp 0.6s ease 0.08s both;">Satu pintu untuk memantau dan menguji integrasi service</h1>
        <p class="hero-subtitle" style="animation: fadeInUp 0.6s ease 0.16s both;">
            Gateway ini membantu tim mendemokan routing API, logging request, API key, tabel shadow, dan analitik penggunaan service dalam satu dashboard yang rapi.
        </p>

        <div class="action-buttons" style="animation: fadeInUp 0.6s ease 0.24s both;">
            <a href="/login" class="btn btn-primary"><i data-lucide="log-in"></i> Masuk ke Dashboard</a>
            <a href="/register" class="btn btn-outline-light"><i data-lucide="user-plus"></i> Daftar Akun</a>
            <a href="/api/status" class="btn btn-outline-light"><i data-lucide="activity"></i> Cek Status API</a>
        </div>

        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="route"></i></div>
                <div class="feature-title">Routing Gateway</div>
                <div class="feature-desc">Request diteruskan ke service aktif berdasarkan konfigurasi database.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="clipboard-list"></i></div>
                <div class="feature-title">Logging Request</div>
                <div class="feature-desc">Setiap traffic gateway dicatat untuk audit, filter, dan kebutuhan demo.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="key-round"></i></div>
                <div class="feature-title">Kunci API</div>
                <div class="feature-desc">User dapat membuat API key dengan batas harian dan scope service.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="bar-chart-3"></i></div>
                <div class="feature-title">Analitik</div>
                <div class="feature-desc">Traffic, tingkat sukses, konsumen, dan tren penggunaan ditampilkan ringkas.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="database"></i></div>
                <div class="feature-title">Tabel Shadow</div>
                <div class="feature-desc">Penggunaan service dicatat ke tabel shadow_service_usage tanpa mengganggu response.</div>
            </div>
            <div class="feature-card">
                <div class="feature-icon"><i data-lucide="id-card"></i></div>
                <div class="feature-title">Data Karyawan</div>
                <div class="feature-desc">Data demo EMP001 sampai EMP005 tersedia untuk bukti repository.</div>
            </div>
        </div>
        <div class="stack-strip" style="animation: fadeInUp 0.5s ease 0.7s both;">
            <div class="stack-title">Teknologi yang digunakan</div>
            <div class="stack-list">
                <span class="stack-pill"><i data-lucide="server" style="width:16px;height:16px"></i> Node.js</span>
                <span class="stack-pill"><i data-lucide="layers" style="width:16px;height:16px"></i> Express</span>
                <span class="stack-pill"><i data-lucide="database" style="width:16px;height:16px"></i> MySQL</span>
                <span class="stack-pill"><i data-lucide="layout-template" style="width:16px;height:16px"></i> EJS</span>
            </div>
        </div>
        <footer style="margin-top: 60px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.1); display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px;">
            <div style="font-size: 13px; color: #94a3b8;">2026 Kelompok 7 - Tugas Besar RPL 2 ULBI</div>
            <div style="display: flex; gap: 16px;">
                <a href="/download-docs" style="font-size: 13px; color: #93c5fd; text-decoration: none;"><i data-lucide="file-text" style="width: 14px; height: 14px; vertical-align: middle;"></i> Dokumentasi</a>
                <a href="/api/status" style="font-size: 13px; color: #93c5fd; text-decoration: none;"><i data-lucide="activity" style="width: 14px; height: 14px; vertical-align: middle;"></i> Status</a>
            </div>
        </footer>
    </div>

    <script>
        window.addEventListener('DOMContentLoaded', () => {
                lucide.createIcons();
                        const toggle = document.getElementById('darkModeToggle');
            if (toggle) {
                const isDark = localStorage.getItem('darkMode') === 'true';
                if (isDark) document.body.classList.add('dark-mode');
                
                toggle.innerHTML = isDark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                if (window.lucide) lucide.createIcons();

                // Hapus event listener lama dengan clone node (jika ada script ganda)
                const newToggle = toggle.cloneNode(true);
                toggle.parentNode.replaceChild(newToggle, toggle);

                newToggle.addEventListener('click', () => {
                    document.body.classList.toggle('dark-mode');
                    const dark = document.body.classList.contains('dark-mode');
                    localStorage.setItem('darkMode', dark);
                    
                    newToggle.innerHTML = dark ? '<i data-lucide="sun"></i>' : '<i data-lucide="moon"></i>';
                    if (window.lucide) lucide.createIcons();
                });
            } else {
                if (localStorage.getItem('darkMode') === 'true') {
                    document.body.classList.add('dark-mode');
                }
            }
            });
    </script>
</body>

</html>
