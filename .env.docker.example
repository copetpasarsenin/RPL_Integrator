# ==============================================================================
# TEMPLATE ENV KHUSUS DOCKER DESKTOP (LOCAL DEMO ONLY)
# Nilai ini hanya untuk demo lokal Docker Desktop, bukan untuk production.
# Jangan gunakan secret/password asli dan jangan commit kredensial nyata.
# ==============================================================================

# Port aplikasi Express di dalam container
PORT=3000

# Mode lingkungan untuk demo lokal Docker
NODE_ENV=development

# Konfigurasi database MySQL container Docker Compose
DB_HOST=mysql
DB_PORT=3306
DB_USER=rpl_user
DB_PASSWORD=rpl_password
DB_NAME=rpl_integrator

# Kredensial root MySQL khusus demo lokal Docker Desktop
MYSQL_ROOT_PASSWORD=rpl_root_password

# JWT demo lokal, minimal 32 karakter
JWT_SECRET=rpl_integrator_very_secure_demo_jwt_secret_key_32_chars
JWT_ISSUER=rpl-integrator
JWT_API_AUDIENCE=integrator-api

# Seed default users demo saat aplikasi berjalan
SEED_DEFAULT_USERS=true

# Trust proxy dimatikan untuk demo lokal Docker Desktop
TRUST_PROXY=false

# Fee gateway demo
GATEWAY_FEE_PERCENT=0.5

# URL service upstream jika service lain berjalan di host komputer
SMARTBANK_URL=http://host.docker.internal:3001
MARKETPLACE_URL=http://host.docker.internal:3002
POS_URL=http://host.docker.internal:3003
SUPPLIERHUB_URL=http://host.docker.internal:3004
LOGISTIKITA_URL=http://host.docker.internal:3005
UMKM_INSIGHT_URL=http://host.docker.internal:3006

# Rate limit gateway per user/API consumer
USER_RATE_WINDOW_MS=60000
USER_RATE_MAX=30

# Timeout request proxy ke service upstream (ms)
PROXY_TIMEOUT_MS=10000