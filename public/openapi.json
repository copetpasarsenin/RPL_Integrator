{
  "openapi": "3.0.3",
  "info": {
    "title": "RPL Integrator Gateway API",
    "version": "3.0.0",
    "description": "API Gateway / Integrator untuk routing request UMKM ke layanan downstream terdaftar."
  },
  "servers": [
    {
      "url": "http://localhost:3000",
      "description": "Pengembangan lokal"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerApiToken": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Gunakan `ApiKey igw_...` atau nilai mentah `igw_...`."
      },
      "csrfToken": {
        "type": "apiKey",
        "in": "header",
        "name": "X-CSRF-Token"
      }
    },
    "schemas": {
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "example": "error" },
          "message": { "type": "string" }
        }
      },
      "GatewayProxyResponse": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["success", "error"] },
          "integrator_info": {
            "type": "object",
            "properties": {
              "service_tujuan": { "type": "string" },
              "fee_percent": { "type": "string" },
              "transaction_amount": { "type": "number" },
              "calculated_fee": { "type": "number" },
              "fee_terpotong": { "type": "number" },
              "fee_status": { "type": "string" },
              "forwarded_to": { "type": "string" },
              "downstream_status": { "type": "integer" }
            }
          },
          "data": { "type": "object", "additionalProperties": true }
        }
      }
    }
  },
  "paths": {
    "/api/status": {
      "get": {
        "summary": "Status gateway",
        "responses": {
          "200": { "description": "Status gateway dan jumlah service" },
          "500": { "description": "Kesalahan database" }
        }
      }
    },
    "/login": {
      "get": {
        "summary": "Halaman login dashboard",
        "responses": {
          "200": { "description": "Halaman login dengan tombol demo satu klik" }
        }
      },
      "post": {
        "summary": "Proses login dashboard",
        "requestBody": {
          "required": false,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "username": { "type": "string" },
                  "password": { "type": "string" },
                  "demo_role": { "type": "string", "enum": ["admin", "operator", "user"] }
                }
              }
            }
          }
        },
        "responses": {
          "302": { "description": "Login berhasil dan diarahkan sesuai role" },
          "401": { "description": "Username atau password salah" }
        }
      }
    },
    "/api/services": {
      "get": {
        "summary": "Daftar service gateway",
        "responses": {
          "200": { "description": "Daftar service yang terdaftar" },
          "401": { "description": "Login dashboard diperlukan" },
          "403": { "description": "Role tidak memiliki izin" }
        }
      }
    },
    "/api/logs": {
      "get": {
        "summary": "Daftar request log terbaru",
        "parameters": [
          { "name": "limit", "in": "query", "required": false, "schema": { "type": "integer", "minimum": 1, "maximum": 200 } }
        ],
        "responses": {
          "200": { "description": "Request log terbaru" },
          "401": { "description": "Login dashboard diperlukan" },
          "403": { "description": "Role tidak memiliki izin" }
        }
      }
    },
    "/api/demo/simulate": {
      "post": {
        "summary": "Simulasi request gateway untuk demo",
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "service": { "type": "string", "example": "smartbank" },
                  "endpoint": { "type": "string", "example": "pembayaran_transaksi" },
                  "amount": { "type": "number", "minimum": 0 },
                  "source_app": { "type": "string", "example": "demo_simulator" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Simulasi berhasil dan dicatat ke request_logs serta shadow_service_usage" },
          "400": { "description": "Input simulasi tidak valid" },
          "401": { "description": "Login dashboard diperlukan" }
        }
      }
    },
    "/api/demo/seed-data": {
      "post": {
        "summary": "Seed data demo untuk presentasi",
        "security": [{ "csrfToken": [] }],
        "responses": {
          "200": { "description": "Data demo request, revenue, alert, dan shadow usage berhasil dibuat" },
          "401": { "description": "Login dashboard diperlukan" },
          "403": { "description": "Hanya admin yang dapat menjalankan seed data" }
        }
      }
    },
    "/generate-test-token": {
      "post": {
        "summary": "Generate JWT API dari session dashboard",
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "user_id": { "type": "string", "description": "Override khusus admin/operator" },
                  "name": { "type": "string", "description": "Override khusus admin/operator" },
                  "npm": { "type": "string", "description": "Override khusus admin/operator" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token API berhasil dibuat" },
          "401": { "description": "Login dashboard diperlukan" },
          "403": { "description": "Token CSRF atau role tidak valid" }
        }
      }
    },
    "/api/tokens/revoke": {
      "post": {
        "summary": "Cabut JWT API sebelum kedaluwarsa",
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["token"],
                "properties": {
                  "token": { "type": "string" },
                  "reason": { "type": "string", "maxLength": 255 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Token berhasil dicabut" },
          "400": { "description": "Token tidak valid" },
          "403": { "description": "Tidak dapat mencabut token milik user lain" }
        }
      }
    },
    "/api/keys": {
      "get": {
        "summary": "Daftar API key user dashboard aktif",
        "security": [{ "csrfToken": [] }],
        "responses": {
          "200": { "description": "Daftar API key" }
        }
      },
      "post": {
        "summary": "Buat API key dengan scope opsional",
        "security": [{ "csrfToken": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["key_name"],
                "properties": {
                  "key_name": { "type": "string", "minLength": 3 },
                  "daily_limit": { "type": "integer", "minimum": 1, "maximum": 100000 },
                  "scopes": {
                    "type": "string",
                    "example": "proxy:smartbank,proxy:marketplace,validation:read"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "API key berhasil dibuat; nilai mentah hanya ditampilkan sekali" },
          "400": { "description": "Validasi gagal" }
        }
      }
    },
    "/integrator/validasi_request": {
      "get": {
        "summary": "Validasi JWT API atau API key",
        "security": [{ "bearerApiToken": [] }, { "apiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Token/key valid" },
          "401": { "description": "Token/key belum dikirim" },
          "403": { "description": "Token/key tidak valid, kedaluwarsa, atau sudah dicabut" }
        }
      }
    },
    "/integrator/routing_api": {
      "get": {
        "summary": "Daftar route gateway aktif",
        "security": [{ "bearerApiToken": [] }, { "apiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Service aktif yang terdaftar" }
        }
      }
    },
    "/integrator/{service}/{path}": {
      "parameters": [
        { "name": "service", "in": "path", "required": true, "schema": { "type": "string" } },
        { "name": "path", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "post": {
        "summary": "Proxy request POST ke service downstream",
        "security": [{ "bearerApiToken": [] }, { "apiKeyAuth": [] }],
        "parameters": [
          {
            "name": "Idempotency-Key",
            "in": "header",
            "required": false,
            "schema": { "type": "string" },
            "description": "Jika dikirim, request identik yang berulang akan memakai ulang response tersimpan."
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "amount": { "type": "number", "minimum": 0 }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Downstream sukses", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/GatewayProxyResponse" } } } },
          "400": { "description": "Body request tidak valid" },
          "403": { "description": "Scope API key tidak mencukupi" },
          "409": { "description": "Konflik idempotency atau request masih diproses" },
          "502": { "description": "Downstream error atau URL service tidak aman" },
          "503": { "description": "Circuit breaker aktif" },
          "504": { "description": "Downstream timeout" }
        }
      }
    },
    "/integrator/{service}": {
      "parameters": [
        { "name": "service", "in": "path", "required": true, "schema": { "type": "string" } }
      ],
      "get": {
        "summary": "Proxy request ke root service downstream",
        "security": [{ "bearerApiToken": [] }, { "apiKeyAuth": [] }],
        "responses": {
          "200": { "description": "Response dari service downstream" },
          "401": { "description": "Token/key belum dikirim" },
          "403": { "description": "Token/key atau scope tidak valid" },
          "502": { "description": "Downstream error atau URL service tidak aman" }
        }
      }
    }
  }
}
