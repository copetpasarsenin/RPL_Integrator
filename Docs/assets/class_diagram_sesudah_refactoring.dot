digraph AfterRefactoring {
  graph [rankdir=LR, bgcolor="white", label="Class Diagram Sesudah Refactoring - Suggested Design", labelloc="t", fontsize=18, fontname="Calibri"];
  node [shape=record, style="rounded,filled", fillcolor="#EAF2F8", color="#1F4E79", fontname="Calibri", fontsize=10];
  edge [color="#555555", arrowsize=0.8, fontname="Calibri", fontsize=9];

  AppBootstrap [label="{AppBootstrap|+ configureExpress()\l+ registerMiddleware()\l+ registerRoutes()\l+ startHealthScheduler()\l}"];
  DashboardRouter [label="{DashboardRouter|+ map dashboard routes\l+ delegate to controllers\l}"];
  DashboardController [label="{DashboardController|+ overview()\l+ services()\l+ analytics()\l+ revenue()\l}"];
  GatewayRouter [label="{GatewayRouter|+ map /integrator routes\l+ call GatewayController\l}"];
  GatewayController [label="{GatewayController|+ handleProxy(req,res)\l+ build response DTO\l}"];
  GatewayService [label="{GatewayService|+ resolveService()\l+ forwardRequest()\l+ calculateFee()\l+ handleIdempotency()\l}"];
  AuthService [label="{AuthService|+ verifySession()\l+ verifyApiToken()\l+ issueToken()\l+ revokeToken()\l}"];
  RateLimitService [label="{RateLimitService|+ checkApiKeyQuota()\l+ checkUserLimit()\l}"];
  HealthService [label="{HealthService|+ checkServices()\l+ saveHistory()\l+ raiseAlert()\l}"];
  ServiceRepository [label="{ServiceRepository|+ findActiveService()\l+ listServices()\l+ updateService()\l}", fillcolor="#EAFAF1"];
  LogRepository [label="{LogRepository|+ saveRequestLog()\l+ saveRevenueLog()\l+ saveAuditLog()\l}", fillcolor="#EAFAF1"];
  UserRepository [label="{UserRepository|+ findUser()\l+ listUsers()\l+ saveApiKey()\l}", fillcolor="#EAFAF1"];
  UrlValidator [label="{UrlValidator|+ assertSafeHttpUrl()\l+ createSafeLookup()\l}"];
  DashboardPresenter [label="{DashboardPresenter|+ formatOverview()\l+ formatCharts()\l+ formatTables()\l}"];
  ViewPartials [label="{EJS Partials|sidebar.ejs\loverview.ejs\lanalytics.ejs\lrevenue.ejs\l}", fillcolor="#F4ECF7"];
  MySQL [label="{MySQL Database|users\lapi_services\lrequest_logs\lrevenue_logs\lapi_keys\l}", fillcolor="#FDEBD0"];
  Upstream [label="{Upstream Services|SmartBank\lMarketplace\lPOS\lSupplierHub\lLogistiKita\lUMKM Insight\l}", fillcolor="#EAFAF1"];

  AppBootstrap -> DashboardRouter;
  AppBootstrap -> GatewayRouter;
  DashboardRouter -> DashboardController;
  DashboardController -> DashboardPresenter;
  DashboardController -> ServiceRepository;
  DashboardController -> LogRepository;
  DashboardController -> UserRepository;
  DashboardController -> ViewPartials;
  GatewayRouter -> GatewayController;
  GatewayController -> AuthService;
  GatewayController -> RateLimitService;
  GatewayController -> GatewayService;
  GatewayService -> ServiceRepository;
  GatewayService -> LogRepository;
  GatewayService -> UrlValidator;
  GatewayService -> Upstream;
  AuthService -> UserRepository;
  RateLimitService -> UserRepository;
  HealthService -> ServiceRepository;
  HealthService -> LogRepository;
  ServiceRepository -> MySQL;
  LogRepository -> MySQL;
  UserRepository -> MySQL;
}
