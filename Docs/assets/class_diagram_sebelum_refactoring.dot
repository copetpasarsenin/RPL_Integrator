digraph BeforeRefactoring {
  graph [rankdir=LR, bgcolor="white", label="Class Diagram Sebelum Refactoring - Current Coupling", labelloc="t", fontsize=18, fontname="Calibri"];
  node [shape=record, style="rounded,filled", fillcolor="#EAF2F8", color="#1F4E79", fontname="Calibri", fontsize=10];
  edge [color="#555555", arrowsize=0.8, fontname="Calibri", fontsize=9];

  Server [label="{server.js / ExpressApp|+ app.get('/dashboard')\l+ app.get('/dashboard/services')\l+ app.get('/dashboard/analytics')\l+ app.get('/api/status')\l+ health check scheduler\l+ user/service/API key CRUD\l}", fillcolor="#FADBD8"];
  GatewayRouter [label="{routes/gateway.js / GatewayRouter|+ router.all('/:service')\l+ router.all('/:service/{*path}')\l+ proxy request\l+ idempotency\l+ revenue logging\l+ shadow usage logging\l}", fillcolor="#FADBD8"];
  AuthMiddleware [label="{middleware/auth.js / AuthMiddleware|+ validateApiToken()\l+ requireAuth()\l+ requireRole()\l+ issueSessionToken()\l+ issueApiToken()\l+ revoke tokens\l+ logAudit()\l}", fillcolor="#FADBD8"];
  RateLimit [label="{middleware/rateLimitPerUser.js|+ enforce API key quota\l+ enforce DB user rate limit\l+ memory fallback\l}"];
  Database [label="{config/database.js|+ create pool\l+ create tables\l+ lightweight migrations\l+ seed services/users/employees\l}", fillcolor="#FADBD8"];
  DashboardView [label="{views/dashboard.ejs|+ sidebar/menu conditions\l+ overview/services/logs/users\l+ analytics/revenue sections\l+ inline Chart.js scripts\l}", fillcolor="#FADBD8"];
  ClientPortal [label="{views/client_portal.ejs|+ token generator UI\l+ API key instructions\l+ request simulator\l+ inline fetch helpers\l}"];
  UrlSafety [label="{utils/urlSafety.js|+ assertSafeHttpUrl()\l+ createSafeLookup()\l+ private IP checks\l}"];
  GatewayUtils [label="{utils/gatewayUtils.js|+ joinUrl()\l+ appendQueryString()\l+ getProxyTimeoutMs()\l}"];
  MySQL [label="{MySQL Tables|users\lapi_services\lrequest_logs\lrevenue_logs\lapi_keys\laudit_logs\l}", shape=record, fillcolor="#FDEBD0"];
  Axios [label="{Axios / Upstream Services|HTTP proxy target\lSmartBank / Marketplace / POS\lSupplierHub / LogistiKita / Insight\l}", fillcolor="#EAFAF1"];

  Server -> AuthMiddleware [label="auth/session"];
  Server -> RateLimit [label="API limiter"];
  Server -> Database [label="queries + init"];
  Server -> DashboardView [label="render data"];
  Server -> ClientPortal [label="render portal"];
  Server -> GatewayRouter [label="mount /integrator"];
  GatewayRouter -> AuthMiddleware [label="validate token"];
  GatewayRouter -> RateLimit [label="quota"];
  GatewayRouter -> Database [label="service/log/revenue"];
  GatewayRouter -> UrlSafety [label="safe URL"];
  GatewayRouter -> GatewayUtils [label="URL helpers"];
  GatewayRouter -> Axios [label="forward request"];
  AuthMiddleware -> Database [label="users, tokens, audit"];
  RateLimit -> Database [label="limits/usage"];
  Database -> MySQL [label="DDL + seed + pool"];
}
