digraph BeforeRefactoring {
  graph [
    rankdir=TB, bgcolor="white", compound=true,
    label="Class Diagram Sebelum Refactoring\nKondisi Coupling Saat Ini",
    labelloc="t", fontsize=16, fontname="Calibri Bold",
    ranksep=0.7, nodesep=0.5, pad=0.3,
    size="11,7!"
  ];
  node [shape=record, style="rounded,filled", fillcolor="#EBF5FB",
        color="#2C3E50", fontname="Calibri", fontsize=9, penwidth=1.2];
  edge [color="#7F8C8D", arrowsize=0.7, fontname="Calibri", fontsize=8];

  /* ── Layer 1: Entry & Routing ── */
  subgraph cluster_entry {
    label="Entry & Routing"; style="rounded,filled";
    fillcolor="#F8F9FA"; color="#BDC3C7"; fontname="Calibri"; fontsize=11;

    Server [label="{server.js / AppEntry|+ 40+ route handlers\l+ dashboard render\l+ API CRUD endpoints\l+ health check scheduler\l+ user/service/key management\l+ analytics/export logic\l}", fillcolor="#FADBD8"];
    GatewayRouter [label="{routes/gateway.js / GatewayRouter|+ proxy forwarding\l+ idempotency check\l+ revenue logging\l+ shadow usage logging\l+ fee calculation\l}", fillcolor="#FADBD8"];
  }

  /* ── Layer 2: Middleware ── */
  subgraph cluster_middleware {
    label="Middleware"; style="rounded,filled";
    fillcolor="#F8F9FA"; color="#BDC3C7"; fontname="Calibri"; fontsize=11;

    AuthMiddleware [label="{middleware/auth.js|+ validateApiToken()\l+ requireAuth()\l+ requireRole()\l+ issueSessionToken()\l+ issueApiToken()\l+ revokeToken()\l+ logAudit()\l}", fillcolor="#FADBD8"];
    Logger [label="{middleware/logger.js|+ logRequest()\l+ updateLogStatus()\l}"];
    CSRF [label="{middleware/csrf.js|+ ensureCsrfToken()\l+ verifyCsrfToken()\l}"];
    RateLimit [label="{middleware/rateLimitPerUser.js|+ enforceApiKeyQuota()\l+ enforceUserRateLimit()\l+ memoryFallback()\l}"];
  }

  /* ── Layer 3: Config & Utils ── */
  subgraph cluster_config {
    label="Config & Utils"; style="rounded,filled";
    fillcolor="#F8F9FA"; color="#BDC3C7"; fontname="Calibri"; fontsize=11;

    DatabaseCfg [label="{config/database.js|+ createPool()\l+ createAllTables()\l+ lightweightMigrations()\l+ seedServices()\l+ seedUsers()\l+ seedEmployees()\l}", fillcolor="#FADBD8"];
    UrlSafety [label="{utils/urlSafety.js|+ assertSafeHttpUrl()\l+ createSafeLookup()\l}"];
    GatewayUtils [label="{utils/gatewayUtils.js|+ joinUrl()\l+ getProxyTimeoutMs()\l}"];
  }

  /* ── Layer 4: Views ── */
  subgraph cluster_views {
    label="Views (Inline Logic)"; style="rounded,filled";
    fillcolor="#F8F9FA"; color="#BDC3C7"; fontname="Calibri"; fontsize=11;

    DashboardView [label="{views/dashboard.ejs|+ sidebar/menu conditions\l+ 14 dashboard sections\l+ inline Chart.js scripts\l+ inline data formatting\l}", fillcolor="#FADBD8"];
    ClientPortal [label="{views/client_portal.ejs|+ token generator UI\l+ request simulator\l+ fetch helpers\l+ expiry warning logic\l}", fillcolor="#FEF9E7"];
    LoginView [label="{views/login.ejs|+ login form\l+ demo buttons\l}"];
  }

  /* ── Layer 5: External / Data ── */
  subgraph cluster_external {
    label="External / Data"; style="rounded,filled";
    fillcolor="#F8F9FA"; color="#BDC3C7"; fontname="Calibri"; fontsize=11;

    MySQL [label="{MySQL Database|users | employees\lapi_services | request_logs\lrevenue_logs | api_keys\laudit_logs | system_alerts\lservice_health_logs\l}", fillcolor="#FDEBD0"];
    Upstream [label="{Upstream Services|SmartBank :3001\lMarketplace :3002\lPOS :3003\lSupplierHub :3004\lLogistiKita :3005\lUMKM Insight :3006\l}", fillcolor="#EAFAF1"];
  }

  /* ── Edges: showing heavy coupling ── */
  Server -> AuthMiddleware [label="auth"];
  Server -> Logger [label="log"];
  Server -> CSRF [label="CSRF"];
  Server -> RateLimit [label="limiter"];
  Server -> DatabaseCfg [label="direct queries", color="#E74C3C", style=bold];
  Server -> DashboardView [label="render", color="#E74C3C", style=bold];
  Server -> ClientPortal [label="render"];
  Server -> LoginView [label="render"];
  Server -> GatewayRouter [label="mount"];

  GatewayRouter -> AuthMiddleware [label="validate"];
  GatewayRouter -> RateLimit [label="quota"];
  GatewayRouter -> DatabaseCfg [label="service/log/revenue", color="#E74C3C", style=bold];
  GatewayRouter -> UrlSafety [label="URL check"];
  GatewayRouter -> GatewayUtils [label="helpers"];
  GatewayRouter -> Upstream [label="proxy"];

  AuthMiddleware -> DatabaseCfg [label="users/tokens/audit", color="#E74C3C", style=bold];
  RateLimit -> DatabaseCfg [label="limits"];

  DatabaseCfg -> MySQL [label="pool + DDL + seed"];
}
